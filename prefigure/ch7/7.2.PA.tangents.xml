<diagram xmlns="https://prefigure.org"
         dimensions="(120,120)">
  <coordinates destination="(5,5,115,115)"
               bbox="(-0.5,-2,3.5,3)">
    <grid spacings="((-0.5,0.5,3.5),(-2,0.5,3))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,1,3)" vlabels="(-2,1,3)"/>
    <definition>g(x) = 0.5*x**2 - 2*x + 1</definition>
    <tangent-line function="g" point="1" domain="(0.75,1.25)" stroke="green"/>
    <tangent-line function="g" point="2" domain="(1.75,2.25)" stroke="green"/>
    <tangent-line function="g" point="3" domain="(2.75,3.25)" stroke="green"/>
    <label anchor="(3.5,0)" alignment="nw" offset="(-3,3)"><m>t</m></label>
    <label anchor="(0,3)" alignment="se" offset="(3,-3)"><m>y</m></label>
  </coordinates>
</diagram>
