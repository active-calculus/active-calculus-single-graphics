<diagram xmlns="https://prefigure.org"
         dimensions="(120,120)">
  <coordinates destination="(5,5,115,115)"
               bbox="(-0.5,-2,3.5,3)">
    <grid spacings="((-0.5,0.5,3.5),(-2,0.5,3))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,1,3)" vlabels="(-2,1,3)"/>
    <label anchor="(3.5,0)" alignment="nw" offset="(-3,3)"><m>t</m></label>
    <label anchor="(0,3)" alignment="se" offset="(3,-3)"><m>y</m></label>
    <definition>f(t,y) = t - 2</definition>
    <slope-field function="f" spacings="((0,0.5,3),(-2,0.5,3))" stroke="lightgreen"/>
    <definition>f1(x) = 0.5*x**2 - 2*x - 2</definition>
    <graph function="f1" stroke="blue" domain="(0,3.5)"/>
    <definition>f2(x) = 0.5*x**2 - 2*x - 1</definition>
    <graph function="f2" stroke="blue" domain="(0,3.5)"/>
    <definition>f3(x) = 0.5*x**2 - 2*x</definition>
    <graph function="f3" stroke="blue" domain="(0,3.5)"/>
    <definition>f4(x) = 0.5*x**2 - 2*x + 1</definition>
    <graph function="f4" stroke="blue" domain="(0,3.5)"/>
    <definition>f5(x) = 0.5*x**2 - 2*x + 2</definition>
    <graph function="f5" stroke="blue" domain="(0,3.5)"/>
    <definition>f6(x) = 0.5*x**2 - 2*x + 3</definition>
    <graph function="f6" stroke="blue" domain="(0,3.5)"/>
  </coordinates>
</diagram>
