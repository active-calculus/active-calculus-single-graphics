<diagram xmlns="https://prefigure.org"
         dimensions="(150,120)">
  <coordinates destination="(5,5,145,115)"
               bbox="(-3,-3,3,15)">
    <grid spacings="((-3,1,3),(-3,3,15))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(-3,1,3)" vlabels="(-3,3,15)"/>
    <label anchor="(3,0)" alignment="nw" offset="(0,3)"><m>x</m></label>
    <label anchor="(0,15)" alignment="se" offset="(3,-3)"><m>y</m></label>
    <definition>f(x) = exp(x)</definition>
    <definition>__a(x) = 1 + x + x**2/2 + x**3/6</definition>
    <definition>__b(x) = 1 + x + x**2/2 + x**3/6 + x**4/24</definition>
    <definition>__c(x) = 1 + x + x**2/2 + x**3/6 + x**4/24 + x**5/120</definition>
    <graph function="__a" N="200" stroke="magenta" cliptobbox="yes"/>
    <graph function="__b" N="200" stroke="blue" cliptobbox="yes"/>
    <graph function="__c" N="200" stroke="green" cliptobbox="yes"/>
    <graph function="f" N="200" stroke="red" cliptobbox="yes"/>
  </coordinates>
</diagram>
