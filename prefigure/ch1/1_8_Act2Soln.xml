<diagram xmlns="https://prefigure.org"
         dimensions="(450, 150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-2,-4,6,4)">
    <grid spacings="((-2,1,6),(-4,1,4))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(2,2,3)" vlabels="(2,2,3)"/>
    <label anchor="(5.2,0.2)"><m>x</m></label>
    <label anchor="(0.1,3.2)"><m>y</m></label>
    <label anchor="(3.8,1.75)"><m>y=f(x)</m></label>
    <definition>f(x) = -0.16667*x**3 + x**2 - 1 + 0.16667*8 - 4</definition>
    <graph function="f" stroke="darkblue" domain="(-2,6)" cliptobbox="yes"/>
    <tangent-line function="f" point="2" stroke="darkgreen" domain="(0.5,3.5)" cliptobbox="yes"/>
    <point p="(2,f(2))" size="2" fill="red" cliptobbox="yes"/>
  </coordinates>
  <coordinates destination="(160,10,290,140)"
               bbox="(-2,-4,6,4)">
    <grid spacings="((-2,1,6),(-4,1,4))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(2,2,3)" vlabels="(2,2,3)"/>
    <label anchor="(5.2,0.2)"><m>x</m></label>
    <label anchor="(0.1,3.2)"><m>y</m></label>
    <label anchor="(2.5,2.2)"><m>y=f'(x)</m></label>
    <definition>f(x) = -0.5*x*(x-4)</definition>
    <graph function="f" stroke="blue" domain="(-2,6)" cliptobbox="yes"/>
  </coordinates>
  <coordinates destination="(310,10,440,140)"
               bbox="(-2,-4,6,4)">
    <grid spacings="((-2,1,6),(-4,1,4))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(2,2,3)" vlabels="(2,2,3)"/>
    <label anchor="(5.2,0.2)"><m>x</m></label>
    <label anchor="(0.1,3.2)"><m>y</m></label>
    <definition>f(x) = -0.5*x*(x-4)</definition>
    <derivative function="f" name="derivative"/>
    <graph function="derivative" stroke="lightblue" domain="(-2,6)" cliptobbox="yes"/>
    <label anchor="(1.5,1.2)" cliptobbox="yes"><m>y=f''(x)</m></label>
  </coordinates>
</diagram>
