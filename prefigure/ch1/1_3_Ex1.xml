<diagram xmlns="https://prefigure.org"
         dimensions="(120, 180)">
  <coordinates destination="(10,10,110,170)"
               bbox="(-1,-6,3,1)">

    <grid spacings="((-1,1,3),(-6,1,1))"
          stroke="lightgray"/>

    <axes decorations="no" hlabels="(1,1,2)" vlabels="(-4,2,1)"/>

    <label anchor="(0.8, -5.8)"><m>y=x-x^2</m></label>
    <label anchor="(1.3, 0.4)"><m>m = f'(2)</m></label>

    <definition>f(x) = x-x*x</definition>
    <graph function="f" stroke="blue" domain="(-1,3)"/>

    <tangent-line function="f" point="2" domain="(1,3)" stroke="darkgreen"/>

    <point p="(2, f(2))" size="2" fill="red"/>
  </coordinates>
</diagram>
