<diagram xmlns="https://prefigure.org"
         dimensions="(300, 150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-1,-1,5,5)">

    <axes decorations="no"/>

    <label anchor="(4.5, 0.2)"><m>x</m></label>
    <label anchor="(0.3, 4.5)"><m>y</m></label>
    <label anchor="(4, 4)"><m>f</m></label>
    <label anchor="(0.9, -0.5)"><m>a</m></label>

    <definition>f(x) = 0.1*x*(x+2)*(x-3) + 2</definition>
    <graph function="f" stroke="blue" domain="(-1,5)" cliptobbox="yes"/>

    <definition>g1(x) = f(1) + (f(2.5)-f(1))/(2.5-1)*(x-1)</definition>
    <graph function="g1" stroke="magenta" domain="(0.2,4.3)" cliptobbox="yes"/>

    <definition>g2(x) = f(1) + (f(2.0)-f(1))/(2.0-1)*(x-1)</definition>
    <graph function="g2" stroke="magenta" domain="(0.0,3.7)" cliptobbox="yes"/>

    <definition>g3(x) = f(1) + (f(1.5)-f(1))/(1.5-1)*(x-1)</definition>
    <graph function="g3" stroke="magenta" domain="(-0.2,2.9)" cliptobbox="yes"/>

    <tangent-line function="f" point="1" domain="(-0.4,2.4)" stroke="darkgreen" cliptobbox="yes"/>

    <point p="(1, f(1))" size="2" fill="red" cliptobbox="yes"/>
    <point p="(2.5, f(2.5))" size="2" fill="magenta" cliptobbox="yes"/>
    <point p="(2.0, f(2.0))" size="2" fill="magenta" cliptobbox="yes"/>
    <point p="(1.5, f(1.5))" size="2" fill="magenta" cliptobbox="yes"/>

    <rectangle lower-left="(0.3, f(1)-0.7)" dimensions="(1.4,1.4)" stroke="lightgray" cliptobbox="yes"/>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(0.3,0.7,1.7,2.1)">

    <rectangle lower-left="(0.3,0.7)" dimensions="(1.4,1.4)" stroke="lightgray"/>

    <definition>f(x) = 0.1*x*(x+2)*(x-3) + 2</definition>
    <graph function="f" stroke="blue" cliptobbox="yes"/>

    <definition>g(x) = f(1) + (f(1.5)-f(1))/(1.5-1)*(x-1)</definition>
    <graph function="g" stroke="magenta" cliptobbox="yes"/>

    <tangent-line function="f" point="1" stroke="darkgreen" cliptobbox="yes"/>

    <point p="(1, f(1))" size="2" fill="red" cliptobbox="yes"/>
    <point p="(1.5, f(1.5))" size="2" fill="magenta" cliptobbox="yes"/>
  </coordinates>
</diagram>
