<diagram xmlns="https://prefigure.org"
         dimensions="(450, 150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-1,-1,4,4)">
    <grid spacings="((-1,1,4),(-1,1,4))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(1,3,2)" vlabels="(2,1,3)"/>
    <definition>f(x) = -0.5*(x-1)**2 + 3</definition>
    <graph function="f" stroke="blue" domain="(-1,4)" cliptobbox="yes"/>
    <point p="(1,3)" size="2" fill="white" cliptobbox="yes"/>
    <label anchor="(1.5,3)" cliptobbox="yes"><m>f</m></label>
  </coordinates>
  <coordinates destination="(160,10,290,140)"
               bbox="(-1,-1,4,4)">
    <grid spacings="((-1,1,4),(-1,1,4))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(1,3,3)" vlabels="(2,1,3)"/>
    <definition>f(x) = -0.5*(x-1)**2 + 3</definition>
    <graph function="f" stroke="blue" domain="(-1,4)" cliptobbox="yes"/>
    <point p="(1,3)" size="2" fill="white" cliptobbox="yes"/>
    <point p="(1,2)" size="2" fill="red" cliptobbox="yes"/>
    <label anchor="(1.5,3)" cliptobbox="yes"><m>g</m></label>
  </coordinates>
  <coordinates destination="(310,10,440,140)"
               bbox="(-1,-1,4,4)">
    <grid spacings="((-1,1,4),(-1,1,4))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(1,3,3)" vlabels="(2,1,3)"/>
    <definition>f(x) = -0.5*(x-1)**2 + 3</definition>
    <graph function="f" stroke="blue" domain="(-1,4)" cliptobbox="yes"/>
    <point p="(1,3)" size="2" fill="red" cliptobbox="yes"/>
    <label anchor="(1.5,3)" cliptobbox="yes"><m>h</m></label>
  </coordinates>
</diagram>
