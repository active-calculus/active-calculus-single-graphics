<diagram xmlns="https://prefigure.org"
         dimensions="(150, 150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-3,-3,3,3)">
    <grid spacings="((-3,1,3),(-3,1,3))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(-2,2,2)" vlabels="(-2,2,2)"/>
    <definition>f(x) = 2*cos(0.5*pi*x) + 0.5</definition>
    <graph function="f" stroke="blue" domain="(-3,3)" cliptobbox="yes"/>
    <tangent-line function="f" point="0.2" stroke="darkgreen" domain="(-0.6,1.0)" cliptobbox="yes"/>
    <point p="(0.2,f(0.2))" size="2" fill="red" cliptobbox="yes"/>
    <label anchor="(0.2,f(0.2))" alignment="ne" offset="(4,4)" cliptobbox="yes"><m>A</m></label>
    <tangent-line function="f" point="2.2" stroke="darkgreen" domain="(1.5,2.9)" cliptobbox="yes"/>
    <point p="(2.2,f(2.2))" size="2" fill="red" cliptobbox="yes"/>
    <label anchor="(2.2,f(2.2))" alignment="se" offset="(4,-4)" cliptobbox="yes"><m>B</m></label>
    <label anchor="(-1.8,f(-1.8))" alignment="s" offset="(0,-2)" cliptobbox="yes"><m>y=f(x)</m></label>
  </coordinates>
</diagram>
