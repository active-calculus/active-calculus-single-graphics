<diagram xmlns="https://prefigure.org"
         dimensions="(150, 150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-3,-20,20,200)">

    <grid spacings="((-3,1,20),(-20,10,200))"
          stroke="lightgray"/>

    <axes decorations="no" hlabels="(0,5,20)" vlabels="(0,50,200)"/>

    <label anchor="(1.1, 180)"><m>s</m></label>
    <label anchor="(18, 10)"><m>t</m></label>

    <definition>f(x) = 100*(cos(.75*x)*exp(-0.2*x) + 1)</definition>
    <graph function="f" stroke="blue" domain="(0,20)" N="1000"
           miterlimit="1"/>
  </coordinates>
</diagram>
