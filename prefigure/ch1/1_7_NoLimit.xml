<diagram xmlns="https://prefigure.org"
         dimensions="(300, 150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-1,-1,4,4)">
    <grid spacings="((-1,1,4),(-1,1,4))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(1,3,2)" vlabels="(2,1,3)"/>
    <definition>f1(x) = 0.5*x+1.5</definition>
    <graph function="f1" stroke="blue" domain="(-1,1)" cliptobbox="yes"/>
    <definition>f2(x) = 3.5-0.5*x</definition>
    <graph function="f2" stroke="blue" domain="(1,4)" cliptobbox="yes"/>
    <point p="(1,2)" size="2" fill="white" cliptobbox="yes"/>
    <point p="(1,3)" size="2" fill="white" cliptobbox="yes"/>
    <label anchor="(1.3,3.1)" cliptobbox="yes"><m>f</m></label>
  </coordinates>
  <coordinates destination="(160,10,290,140)"
               bbox="(-1,-1,4,4)">
    <grid spacings="((-1,1,4),(-1,1,4))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(1,3,3)" vlabels="(1,1,3)"/>
    <definition>f1(x) = 0.5*x+1.5</definition>
    <graph function="f1" stroke="blue" domain="(-1,1)" cliptobbox="yes"/>
    <definition>f2(x) = sin(pi/(x-1))+2</definition>
    <graph function="f2" stroke="blue" domain="(1.001,4)" miterlimit="1" N="3000" cliptobbox="yes"/>
    <label anchor="(2.5,3.1)" cliptobbox="yes"><m>g</m></label>
  </coordinates>
</diagram>
