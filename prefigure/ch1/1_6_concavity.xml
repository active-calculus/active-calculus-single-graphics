<diagram xmlns="https://prefigure.org"
         dimensions="(300, 150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-1,-1,3,3)">
    <grid spacings="((-1,1,3),(-1,1,3))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f(x) = 0.5*(x-1)**2 + 0.5</definition>
    <graph function="f" stroke="blue" domain="(-0.8,2.8)" cliptobbox="yes"/>
    <tangent-line function="f" point="-0.5" stroke="darkgreen" domain="(-0.9,-0.1)" cliptobbox="yes"/>
    <point p="(-0.5,f(-0.5))" size="2" fill="red" cliptobbox="yes"/>
    <tangent-line function="f" point="0.5" stroke="darkgreen" domain="(0.1,0.9)" cliptobbox="yes"/>
    <point p="(0.5,f(0.5))" size="2" fill="red" cliptobbox="yes"/>
    <tangent-line function="f" point="1.5" stroke="darkgreen" domain="(1.1,1.9)" cliptobbox="yes"/>
    <point p="(1.5,f(1.5))" size="2" fill="red" cliptobbox="yes"/>
    <tangent-line function="f" point="2.5" stroke="darkgreen" domain="(2.1,2.9)" cliptobbox="yes"/>
    <point p="(2.5,f(2.5))" size="2" fill="red" cliptobbox="yes"/>
  </coordinates>
  <coordinates destination="(160,10,290,140)"
               bbox="(-1,-1,3,3)">
    <grid spacings="((-1,1,3),(-1,1,3))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f(x) = 2.5 - 0.5*(x-1)**2</definition>
    <graph function="f" stroke="blue" domain="(-0.8,2.9)" cliptobbox="yes"/>
    <tangent-line function="f" point="-0.5" stroke="darkgreen" domain="(-0.9,-0.1)" cliptobbox="yes"/>
    <point p="(-0.5,f(-0.5))" size="2" fill="red" cliptobbox="yes"/>
    <tangent-line function="f" point="0.5" stroke="darkgreen" domain="(0.1,0.9)" cliptobbox="yes"/>
    <point p="(0.5,f(0.5))" size="2" fill="red" cliptobbox="yes"/>
    <tangent-line function="f" point="1.5" stroke="darkgreen" domain="(1.1,1.9)" cliptobbox="yes"/>
    <point p="(1.5,f(1.5))" size="2" fill="red" cliptobbox="yes"/>
    <tangent-line function="f" point="2.5" stroke="darkgreen" domain="(2.1,2.9)" cliptobbox="yes"/>
    <point p="(2.5,f(2.5))" size="2" fill="red" cliptobbox="yes"/>
  </coordinates>
</diagram>
