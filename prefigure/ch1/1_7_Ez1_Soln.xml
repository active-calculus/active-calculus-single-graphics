<diagram xmlns="https://prefigure.org"
         dimensions="(150, 150)">
  <coordinates destination="(5,5,145,145)"
               bbox="(-3,-2,3,4)">
    <grid spacings="((-3,0.5,3),(-2,0.5,4))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(-2,1,2)" vlabels="(-1,1,3)"/>
    <label anchor="(-2,2.5)"><m>p</m></label>
    <definition>f1(x) = 2</definition>
    <graph function="f1" stroke="blue" domain="(-3.5,-1)" cliptobbox="yes"/>
    <definition>f2(x) = x**2 + 1</definition>
    <graph function="f2" stroke="blue" domain="(-1,1)" cliptobbox="yes"/>
    <definition>f3(x) = 2</definition>
    <graph function="f3" stroke="blue" domain="(1,3.5)" cliptobbox="yes"/>
    <point p="(-1,3)" size="2" fill="blue" cliptobbox="yes"/>
    <point p="(-1,2)" size="2" fill="white" cliptobbox="yes"/>
  </coordinates>
</diagram>
