<diagram xmlns="https://prefigure.org"
         dimensions="(300, 225)">
  <coordinates destination="(5,5,140,215)"
               bbox="(-1,-5,5,5)">
    <grid spacings="((-1,1,5),(-5,1,5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,1,4)" vlabels="(-4,1,4)"/>
    <label anchor="(4.1,0.1)" alignment="ne" offset="(2,2)"><m>m=-4</m></label>
    <label anchor="(2.3,-3)" alignment="ne" offset="(2,2)"><m>y = f(x)</m></label>
    <definition>f(x) = 4*x-x*x</definition>
    <graph function="f" stroke="blue" cliptobbox="yes"/>
    <tangent-line function="f" point="0" stroke="green" domain="(-0.4,0.4)" cliptobbox="yes"/>
    <label anchor="(0.1,0.1)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>m=4</m></label>
    <tangent-line function="f" point="1" stroke="cyan" domain="(0.6,1.4)" cliptobbox="yes"/>
    <label anchor="(1.1,3.1)" alignment="ne" offset="(4,2)" cliptobbox="yes"><m>m=2</m></label>
    <tangent-line function="f" point="2" stroke="orange" domain="(1.6,2.4)" cliptobbox="yes"/>
    <label anchor="(2,4.1)" alignment="n" offset="(2,2)" cliptobbox="yes"><m>m=0</m></label>
    <tangent-line function="f" point="3" stroke="red" domain="(2.6,3.4)" cliptobbox="yes"/>
    <label anchor="(3.1,3.1)" alignment="ne" offset="(0,2)" cliptobbox="yes"><m>m=-2</m></label>
    <tangent-line function="f" point="4" stroke="darkgreen" domain="(3.6,4.4)" cliptobbox="yes"/>
  </coordinates>
  <coordinates destination="(160,5,295,215)"
               bbox="(-1,-5,5,5)">
    <grid spacings="((-1,1,5),(-5,1,5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,1,4)" vlabels="(-4,1,4)"/>
    <label anchor="(1.2,-3)" alignment="ne" offset="(2,2)"><m>y = f'(x)</m></label>
    <definition>f(x) = 4-2*x</definition>
    <graph function="f" stroke="lightblue" cliptobbox="yes"/>
    <point p="(0,4)" size="2" fill="green" cliptobbox="yes"/>
    <label anchor="(0.1,4.1)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>(0,4)</m></label>
    <point p="(1,2)" size="2" fill="cyan" cliptobbox="yes"/>
    <label anchor="(1.1,2.1)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>(1,2)</m></label>
    <point p="(2,0)" size="2" fill="orange" cliptobbox="yes"/>
    <label anchor="(2.1,0.1)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>(2,0)</m></label>
    <point p="(3,-2)" size="2" fill="red" cliptobbox="yes"/>
    <label anchor="(3.1,-1.9)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>(3,-2)</m></label>
    <point p="(4,-4)" size="2" fill="darkgreen" cliptobbox="yes"/>
    <label anchor="(3.9,-4.1)" alignment="sw" offset="(-2,-2)" cliptobbox="yes"><m>(4,-4)</m></label>
  </coordinates>
</diagram>
