<diagram xmlns="https://prefigure.org"
         dimensions="(150, 150)">
  <coordinates destination="(5,5,145,145)"
               bbox="(-4,-4,4,4)">
    <grid spacings="((-4,0.5,4),(-4,0.5,4))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(-3,1,3)" vlabels="(-3,1,3)"/>
    <label anchor="(-2.8,3.2)"><m>f</m></label>
    <definition>f1(x) = 1+2*(x+4)**2</definition>
    <graph function="f1" stroke="blue" domain="(-4,-3)"/>
    <definition>f2(x) = 3-(x+3)</definition>
    <graph function="f2" stroke="blue" domain="(-3,-2)"/>
    <definition>f3(x) = 0.75*x**2-4</definition>
    <graph function="f3" stroke="blue" domain="(-2,1)"/>
    <definition>f4(x) = -3.25 + 0.75*(x-1)</definition>
    <graph function="f4" stroke="blue" domain="(1,2)"/>
    <definition>f5(x) = -2.5 + sin(pi/(x-2))</definition>
    <graph function="f5" stroke="blue" domain="(2.002,4)" miterlimit="1" N="1000"/>
    <point p="(-2,2)" size="1.5" fill="white"/>
    <point p="(-2,-1)" size="1.5" fill="blue"/>
    <point p="(-1,-3.25)" size="1.5" fill="white"/>
    <point p="(-1,1)" size="1.5" fill="blue"/>
    <point p="(3,-2.5)" size="1.5" fill="white"/>
  </coordinates>
</diagram>
