<diagram xmlns="https://prefigure.org"
         dimensions="(150, 150)">
  <coordinates destination="(5,5,145,145)"
               bbox="(-5,-5,2,2)">
    <grid spacings="((-5,1,2),(-5,1,2))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f1(x) = -2 + 3*(x+1) + (x+1)**2</definition>
    <graph function="f1" stroke="blue" domain="(-5,0)" cliptobbox="yes"/>
    <definition>f2(x) = -2 + 3*(x+1)</definition>
    <graph function="f2" stroke="darkgreen" domain="(-5,2)" cliptobbox="yes"/>
    <point p="(-1,-2)" size="2" fill="red" cliptobbox="yes"/>
    <label anchor="(-2.7,1)" alignment="nw" offset="(-2,2)" cliptobbox="yes"><m>y = g(x)</m></label>
    <label anchor="(-1.85,-5)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>y = L(x)</m></label>
    <label anchor="(-1,-2)" alignment="nw" offset="(-4,4)" cliptobbox="yes"><m>(-1,-2)</m></label>
  </coordinates>
</diagram>
