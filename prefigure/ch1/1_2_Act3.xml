<diagram xmlns="https://prefigure.org"
         dimensions="(150, 150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-1.5,-1.5,5.5,5.5)">

    <grid spacings="((-1.5,0.5,5.5),(-1.5,0.5,5.5))"
          stroke="lightgray"/>

    <axes decorations="no" hlabels="(1,2,5)" vlabels="(1,2,5)"/>

    <label anchor="(4.7, 0.3)"><m>t</m></label>
    <label anchor="(3.8, 4.7)"><m>s</m></label>

    <definition>f(x) = x + 0.5*sin(pi*x)</definition>
    <graph function="f" stroke="blue" domain="(-1.5,5.5)" N="1000"/>
  </coordinates>
</diagram>
