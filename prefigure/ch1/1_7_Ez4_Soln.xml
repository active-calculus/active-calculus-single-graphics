<diagram xmlns="https://prefigure.org"
         dimensions="(300, 150)">
  <coordinates destination="(5,5,145,145)"
               bbox="(-3.5,-3.5,3.5,3.5)">
    <grid spacings="((-3.5,0.5,3.5),(-3.5,0.5,3.5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(-3,3,3)" vlabels="(-3,3,3)"/>
    <label anchor="(1,2.2)"><m>y=g(x)</m></label>
    <definition>f1(x) = (-x)**(0.5)</definition>
    <graph function="f1" stroke="blue" domain="(-3.5,-0.001)" cliptobbox="yes"/>
    <definition>f2(x) = x**(0.5)</definition>
    <graph function="f2" stroke="blue" domain="(0,3.5)" cliptobbox="yes"/>
  </coordinates>
  <coordinates destination="(155,5,295,145)"
               bbox="(-3.5,-3.5,3.5,3.5)">
    <grid spacings="((-3.5,0.5,3.5),(-3.5,0.5,3.5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(-3,1,3)" vlabels="(-3,1,3)"/>
    <label anchor="(1,2.2)"><m>y=g'(x)</m></label>
    <definition>g1(x) = 0.5/((-x)**(0.5))</definition>
    <graph function="g1" stroke="blue" domain="(-3.5,-0.01)" cliptobbox="yes"/>
    <definition>g2(x) = 0.5/(x**(0.5))</definition>
    <graph function="g2" stroke="blue" domain="(0.01,3.5)" cliptobbox="yes"/>
  </coordinates>
</diagram>
