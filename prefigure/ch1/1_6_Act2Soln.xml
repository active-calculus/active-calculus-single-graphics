<diagram xmlns="https://prefigure.org"
         dimensions="(360, 360)">
  <coordinates destination="(5,245,175,355)"
               bbox="(-6,-4,6,4)">
    <grid spacings="((-6,1,6),(-4,1,4))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f(x) = -0.03*(x-5)*x*(x+4)-1</definition>
    <graph function="f" stroke="blue" cliptobbox="yes"/>
    <label anchor="(0.2,3.2)" alignment="ne" offset="(2,2)" scale="0.8" cliptobbox="yes"><m>f</m></label>
    <label anchor="(5.2,-0.2)" alignment="se" offset="(2,-2)" scale="0.8" cliptobbox="yes"><m>x</m></label>
  </coordinates>
  <coordinates destination="(5,125,175,235)"
               bbox="(-6,-4,6,4)">
    <grid spacings="((-6,1,6),(-4,1,4))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f(x) = -0.03*(x-5)*x*(x+4)-1</definition>
    <derivative function="f" name="derivative"/>
    <graph function="derivative" stroke="green"/>
    <label anchor="(0.2,3.2)" alignment="ne" offset="(2,2)" scale="0.8"><m>f'</m></label>
    <label anchor="(5.2,-0.2)" alignment="se" offset="(2,-2)" scale="0.8"><m>x</m></label>
  </coordinates>
  <coordinates destination="(5,5,175,115)"
               bbox="(-6,-4,6,4)">
    <grid spacings="((-6,1,6),(-4,1,4))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f(x) = -0.03*(x-5)*x*(x+4)-1</definition>
    <derivative function="f" name="derivative"/>
    <derivative function="derivative" name="secondderivative"/>
    <graph function="secondderivative" stroke="red"/>
    <label anchor="(0.2,3.2)" alignment="ne" offset="(2,2)" scale="0.8"><m>f''</m></label>
    <label anchor="(5.2,-0.2)" alignment="se" offset="(2,-2)" scale="0.8"><m>x</m></label>
  </coordinates>
  <coordinates destination="(190,245,355,355)"
               bbox="(-6,-4,6,4)">
    <grid spacings="((-6,1,6),(-4,1,4))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f(x) = 2*exp(-0.2*(x**2))*(1+cos(x**2))-1</definition>
    <graph function="f" stroke="blue" cliptobbox="yes"/>
    <label anchor="(0.2,3.2)" alignment="ne" offset="(2,2)" scale="0.8" cliptobbox="yes"><m>f</m></label>
    <label anchor="(5.2,-0.2)" alignment="se" offset="(2,-2)" scale="0.8" cliptobbox="yes"><m>x</m></label>
  </coordinates>
  <coordinates destination="(190,125,355,235)"
               bbox="(-6,-4,6,4)">
    <grid spacings="((-6,1,6),(-4,1,4))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f(x) = 2*exp(-0.2*(x**2))*(1+cos(x**2))-1</definition>
    <derivative function="f" name="derivative"/>
    <graph function="derivative" stroke="green" N="2000"/>
    <label anchor="(0.2,3.2)" alignment="ne" offset="(2,2)" scale="0.8"><m>f'</m></label>
    <label anchor="(5.2,-0.2)" alignment="se" offset="(2,-2)" scale="0.8"><m>x</m></label>
  </coordinates>
  <coordinates destination="(190,5,355,115)"
               bbox="(-6,-12,6,12)">
    <grid spacings="((-6,1,6),(-12,3,12))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f(x) = 2*exp(-0.2*(x**2))*(1+cos(x**2))-1</definition>
    <derivative function="f" name="derivative"/>
    <derivative function="derivative" name="secondderivative"/>
    <graph function="secondderivative" stroke="red" N="2000"/>
    <label anchor="(0.2,9.6)" alignment="ne" offset="(2,2)" scale="0.8"><m>f''</m></label>
    <label anchor="(5.2,-0.2)" alignment="se" offset="(2,-2)" scale="0.8"><m>x</m></label>
  </coordinates>
</diagram>
