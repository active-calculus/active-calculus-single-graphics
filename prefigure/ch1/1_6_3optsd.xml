<diagram xmlns="https://prefigure.org"
         dimensions="(450, 150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-1,-1,3,3)">
    <grid spacings="((-1,1,3),(-1,1,3))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f(x) = 2.5*exp(-0.9*x)+0.25</definition>
    <graph function="f" stroke="blue" domain="(0.25,2.75)" cliptobbox="yes"/>
  </coordinates>
  <coordinates destination="(160,10,290,140)"
               bbox="(-1,-1,3,3)">
    <grid spacings="((-1,1,3),(-1,1,3))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f(x) = 2.5 - 0.75*x</definition>
    <graph function="f" stroke="blue" domain="(0.25,2.75)" cliptobbox="yes"/>
  </coordinates>
  <coordinates destination="(310,10,440,140)"
               bbox="(-1,-1,3,3)">
    <grid spacings="((-1,1,3),(-1,1,3))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f(x) = 2.75 - 2.25*exp(0.75*(x-2.5))</definition>
    <graph function="f" stroke="blue" domain="(0.25,2.65)" cliptobbox="yes"/>
  </coordinates>
</diagram>
