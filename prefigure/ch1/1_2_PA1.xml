<diagram xmlns="https://prefigure.org"
         dimensions="(165, 150)">
  <coordinates destination="(5,5,160,145)"
               bbox="(-2.5,-1.5,3.5,4.5)">

    <grid spacings="((-2.5,0.5,3.5),(-1.5,0.5,4.5))"
          stroke="lightgray"/>

    <axes decorations="no" hlabels="(-2,1,3)" vlabels="(-1,1,3)"/>

    <label anchor="(-1.2, 3.2)"><m>g</m></label>

    <definition>f(x) = -(x*x-4)</definition>
    <graph function="f" stroke="blue" domain="(-2.35,1)"/>

    <definition>__a(x) = -x+3</definition>
    <graph function="__a" stroke="blue" domain="(1,3.5)"/>

    <point p="(0, 4)" size="2" fill="white"/>
    <point p="(1, 2)" size="2" fill="white"/>
    <point p="(0, 1)" size="2" fill="blue"/>
    <point p="(1, 3)" size="2" fill="blue"/>
    <point p="(2, 1)" size="2" fill="white"/>
  </coordinates>
</diagram>
