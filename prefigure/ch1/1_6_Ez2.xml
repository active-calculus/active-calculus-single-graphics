<diagram xmlns="https://prefigure.org"
         dimensions="(150, 120)">
  <coordinates destination="(10,10,140,110)"
               bbox="(-4,-1,4,5)">
    <grid spacings="((-4,1,4),(-2,1,5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(-3,2,3)" vlabels="(0,2,4)"/>
    <label anchor="(-3.2,4.2)"><m>y=g'(x)</m></label>
    <definition>f(x) = sin(3*x) + cos(5*x) + 2.5</definition>
    <graph function="f" stroke="blue" miterlimit="1" N="1000" cliptobbox="yes"/>
  </coordinates>
</diagram>
