<diagram xmlns="https://prefigure.org"
         dimensions="(300, 150)">
  <coordinates destination="(5,5,145,145)"
               bbox="(-1,-1,4,4)">
    <grid spacings="((-1,0.5,4),(-1,0.5,4))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,1,3)" vlabels="(0,1,3)"/>
    <definition>f(x) = 4 - 3*2**(-x)</definition>
    <graph function="f" stroke="blue" domain="(-1,4)" cliptobbox="yes"/>
    <definition>g1(x) = f(1) + (f(2)-f(1))/(2-1)*(x-1)</definition>
    <graph function="g1" stroke="gray" domain="(0.4,2.6)" cliptobbox="yes"/>
    <definition>g2(x) = f(3) + (f(3)-f(2))/(3-2)*(x-3)</definition>
    <graph function="g2" stroke="gray" domain="(1.4,3.6)" cliptobbox="yes"/>
    <tangent-line function="f" point="2" stroke="darkgreen" domain="(0.6,3.4)" cliptobbox="yes"/>
    <point p="(1,f(1))" size="2" fill="red" cliptobbox="yes"/>
    <point p="(2,f(2))" size="2" fill="red" cliptobbox="yes"/>
    <point p="(3,f(3))" size="2" fill="red" cliptobbox="yes"/>
  </coordinates>
  <coordinates destination="(155,5,295,145)"
               bbox="(-1,-1,4,4)">
    <grid spacings="((-1,0.5,4),(-1,0.5,4))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,1,3)" vlabels="(0,1,3)"/>
    <definition>f(x) = 4 - 3*2**(-x)</definition>
    <graph function="f" stroke="blue" domain="(-1,4)" cliptobbox="yes"/>
    <tangent-line function="f" point="2" stroke="darkgreen" domain="(0.6,3.4)" cliptobbox="yes"/>
    <definition>g(x) = f(1) + (f(3)-f(1))/(3-1)*(x-1)</definition>
    <graph function="g" stroke="red" domain="(0.4,3.6)" cliptobbox="yes"/>
    <point p="(1,f(1))" size="2" fill="red" cliptobbox="yes"/>
    <point p="(2,f(2))" size="2" fill="red" cliptobbox="yes"/>
    <point p="(3,f(3))" size="2" fill="red" cliptobbox="yes"/>
  </coordinates>
</diagram>
