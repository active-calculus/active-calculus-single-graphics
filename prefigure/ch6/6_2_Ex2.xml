<diagram xmlns="https://prefigure.org"
         dimensions="(300,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-3,-5,3,5)">
    <grid spacings="((-3,6,3),(-5,10,5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,2,2)" vlabels="(0,5,4)"/>
    <definition>f1(x) = 4 - x**2</definition>
    <definition>g1(x) = x + 2</definition>
    <area-under-curve function="f1" lower="g1" domain="(-2,1)" fill="lightgray"/>
    <definition>f2(x) = -(4 - x**2)</definition>
    <definition>g2(x) = -(x + 2)</definition>
    <area-under-curve function="g2" lower="f2" domain="(-2,1)" fill="lightgray"/>
    <graph function="f1" stroke="darkblue" domain="(-2,1)" cliptobbox="yes"/>
    <graph function="f2" stroke="darkblue" domain="(-2,1)" cliptobbox="yes"/>
    <definition>f3(x) = x + 2</definition>
    <graph function="f3" stroke="darkgreen" domain="(-2,1)" cliptobbox="yes"/>
    <definition>f4(x) = -(x + 2)</definition>
    <graph function="f4" stroke="darkgreen" domain="(-2,1)" cliptobbox="yes"/>
    <definition>__a(t) = (0.4*cos(t)-1.2, 3*sin(t))</definition>
    <parametric-curve function="__a" domain="(0.5*pi, 1.5*pi)" stroke="red" cliptobbox="yes"/>
    <definition>__b(t) = (0.4*cos(t)-0.8, 3*sin(t))</definition>
    <parametric-curve function="__b" domain="(0, 2*pi)" stroke="red" cliptobbox="yes"/>
    <definition>__c(t) = (0.1*cos(t)-0.8, 1.1*sin(t))</definition>
    <parametric-curve function="__c" domain="(0, 2*pi)" stroke="magenta" cliptobbox="yes"/>
    <definition>__d(t) = (0.2*cos(t)+1, 3*sin(t))</definition>
    <parametric-curve function="__d" domain="(0, 2*pi)" stroke="darkblue" cliptobbox="yes"/>
    <line endpoints="((-1.2,3),(-0.8,3))" stroke="red" cliptobbox="yes"/>
    <line endpoints="((-1.2,-3),(-0.8,-3))" stroke="red" cliptobbox="yes"/>
    <label anchor="(-1,-3.7)" alignment="c" cliptobbox="yes"><m>\triangle x</m></label>
    <label anchor="(-0.1,4.1)" alignment="nw" offset="(-2,2)" cliptobbox="yes"><m>4</m></label>
    <label anchor="(0.1,4.3)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>y</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(-4,-4,4,4)">
    <grid spacings="((-4,8,4),(-4,8,4))" stroke="lightgray"/>
    <axes decorations="no"/>
    <circle center="(0,0)" radius="3" fill="lightgray"/>
    <circle center="(0,0)" radius="1" fill="white"/>
    <definition>__a(t) = (3*cos(t), 3*sin(t))</definition>
    <parametric-curve function="__a" domain="(0, 2*pi)" stroke="red"/>
    <definition>__b(t) = (cos(t), sin(t))</definition>
    <parametric-curve function="__b" domain="(0, 2*pi)" stroke="magenta"/>
    <line endpoints="((0,0),(1,0))" stroke="black"/>
    <line endpoints="((0,0),(2.1213,2.1213))" stroke="black"/>
    <label anchor="(0.5,-0.75)" alignment="n" offset="(0,2)" scale="0.8"><m>r(x)</m></label>
    <label anchor="(1.0607,1.0607)" alignment="se" offset="(2,-2)" scale="0.8"><m>R(x)</m></label>
  </coordinates>
</diagram>
