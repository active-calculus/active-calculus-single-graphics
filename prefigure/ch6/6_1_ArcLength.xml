<diagram xmlns="https://prefigure.org"
         dimensions="(300,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-1,-1,5,5)">
    <axes decorations="no"/>
    <definition>f(x) = 0.1*x*(x+2)*(x-3) + 2</definition>
    <graph function="f" stroke="blue" domain="(-1,5)" cliptobbox="yes"/>
    <definition>g1(x) = f(1) + (f(2)-f(1))*(x-1)</definition>
    <graph function="g1" stroke="green" domain="(1,2)" cliptobbox="yes"/>
    <definition>g2(x) = f(2) + (f(3)-f(2))*(x-2)</definition>
    <graph function="g2" stroke="green" domain="(2,3)" cliptobbox="yes"/>
    <definition>g3(x) = f(3) + (f(4)-f(3))*(x-3)</definition>
    <graph function="g3" stroke="green" domain="(3,4)" cliptobbox="yes"/>
    <point p="(1,f(1))" size="1.5" fill="blue" cliptobbox="yes"/>
    <point p="(2,f(2))" size="1.5" fill="blue" cliptobbox="yes"/>
    <point p="(3,f(3))" size="1.5" fill="blue" cliptobbox="yes"/>
    <point p="(4,f(4))" size="1.5" fill="blue" cliptobbox="yes"/>
    <rectangle lower-left="(1.7,0.8)" dimensions="(1.6,1.6)" stroke="lightgray" cliptobbox="yes"/>
    <label anchor="(4.5,0.2)"><m>x</m></label>
    <label anchor="(0.3,4.5)"><m>y</m></label>
    <label anchor="(3.8,4)"><m>f</m></label>
    <label anchor="(1,-0.5)" alignment="n"><m>x_0</m></label>
    <label anchor="(2,-0.5)" alignment="n"><m>x_1</m></label>
    <label anchor="(3,-0.5)" alignment="n"><m>x_2</m></label>
    <label anchor="(4,-0.5)" alignment="n"><m>x_3</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(1.7,0.9,3.3,2.5)">
    <rectangle lower-left="(1.7,0.9)" dimensions="(1.6,1.6)" stroke="lightgray"/>
    <definition>f(x) = 0.1*x*(x+2)*(x-3) + 2</definition>
    <graph function="f" stroke="blue" cliptobbox="yes"/>
    <definition>g1(x) = f(1) + (f(2)-f(1))*(x-1)</definition>
    <graph function="g1" stroke="green" domain="(1,2)" cliptobbox="yes"/>
    <definition>g2(x) = f(2) + (f(3)-f(2))*(x-2)</definition>
    <graph function="g2" stroke="green" domain="(2,3)" cliptobbox="yes"/>
    <definition>g3(x) = f(3) + (f(4)-f(3))*(x-3)</definition>
    <graph function="g3" stroke="green" domain="(3,4)" cliptobbox="yes"/>
    <line endpoints="((3,1.2),(3,2.0))" stroke="black" cliptobbox="yes"/>
    <line endpoints="((2,1.2),(3,1.2))" stroke="black" cliptobbox="yes"/>
    <point p="(2,f(2))" size="2" fill="blue" cliptobbox="yes"/>
    <point p="(3,f(3))" size="2" fill="blue" cliptobbox="yes"/>
    <label anchor="(2.5,1.2)" alignment="s" offset="(0,-2)" cliptobbox="yes"><m>\triangle x</m></label>
    <label anchor="(3,1.6)" alignment="e" offset="(2,0)" cliptobbox="yes"><m>\triangle y</m></label>
    <label anchor="(2.5,1.6)" alignment="nw" offset="(-2,2)" cliptobbox="yes"><m>h</m></label>
    <label anchor="(2.5,1.4375)" alignment="se" offset="(2,-2)" cliptobbox="yes"><m>L_{\text{slice}}</m></label>
  </coordinates>
</diagram>
