<diagram xmlns="https://prefigure.org"
         dimensions="(150,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-3,-5,3,5)">
    <grid spacings="((-3,6,3),(-5,10,5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,2,2)" vlabels="(0,4,4)"/>
    <definition>f1(x) = 4 - x**2</definition>
    <graph function="f1" stroke="darkblue" domain="(-2,2)" cliptobbox="yes"/>
    <definition>f2(x) = -(4 - x**2)</definition>
    <graph function="f2" stroke="darkblue" domain="(-2,2)" cliptobbox="yes"/>
    <definition>__a(t) = (0.4*cos(t)-1.2, 3*sin(t))</definition>
    <parametric-curve function="__a" domain="(0.5*pi, 1.5*pi)" stroke="red" cliptobbox="yes"/>
    <definition>__b(t) = (0.4*cos(t)-0.8, 3*sin(t))</definition>
    <parametric-curve function="__b" domain="(0, 2*pi)" stroke="red" cliptobbox="yes"/>
    <definition>__c(t) = (0.5*cos(t), 4*sin(t))</definition>
    <parametric-curve function="__c" domain="(0.5*pi, 1.5*pi)" stroke="darkblue" cliptobbox="yes"/>
    <parametric-curve function="__c" domain="(-0.5*pi, 0.5*pi)" stroke="lightblue" dash="1 1" cliptobbox="yes"/>
    <line endpoints="((-1.2,3),(-0.8,3))" stroke="red" cliptobbox="yes"/>
    <line endpoints="((-1.2,-3),(-0.8,-3))" stroke="red" cliptobbox="yes"/>
    <line endpoints="((-1,-0.2),(-1,0.2))" stroke="black" cliptobbox="yes"/>
    <label anchor="(-1,-3.5)" alignment="c" cliptobbox="yes"><m>\triangle x</m></label>
    <label anchor="(-1,-0.7)" alignment="c" cliptobbox="yes"><m>x</m></label>
    <label anchor="(0.1,4.3)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>y</m></label>
    <label anchor="(0.5,3.5)" alignment="ne" offset="(3,4)" cliptobbox="yes"><m>y=4-x^2</m></label>
  </coordinates>
</diagram>
