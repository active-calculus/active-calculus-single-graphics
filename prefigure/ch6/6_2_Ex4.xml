<diagram xmlns="https://prefigure.org"
         dimensions="(225,225)">
  <coordinates destination="(10,10,215,215)"
               bbox="(-1.5,-3.5,3.5,1.5)">
    <grid spacings="((-1.5,5,3.5),(-3.5,5,1.5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,1,1)" vlabels="(-2,3,1)"/>
    <definition>f1(x) = x</definition>
    <definition>g1(x) = x**2</definition>
    <area-under-curve function="f1" lower="g1" domain="(0,1)" fill="lightgray"/>
    <definition>f2(x) = -x - 2</definition>
    <definition>g2(x) = -x**2 - 2</definition>
    <area-under-curve function="g2" lower="f2" domain="(0,1)" fill="lightgray"/>
    <graph function="f1" stroke="darkblue" domain="(0,1)" cliptobbox="yes"/>
    <graph function="f2" stroke="darkblue" domain="(0,1)" cliptobbox="yes"/>
    <graph function="g1" stroke="darkgreen" domain="(0,1)" cliptobbox="yes"/>
    <graph function="g2" stroke="darkgreen" domain="(0,1)" cliptobbox="yes"/>
    <definition>__a(t) = (0.1*cos(t)+0.4, 1.5*sin(t)-1)</definition>
    <parametric-curve function="__a" domain="(0.5*pi, 1.5*pi)" stroke="red" cliptobbox="yes"/>
    <definition>__b(t) = (0.1*cos(t)+0.6, 1.5*sin(t)-1)</definition>
    <parametric-curve function="__b" domain="(0, 2*pi)" stroke="red" cliptobbox="yes"/>
    <definition>__c(t) = (0.05*cos(t)+0.6, 1.25*sin(t)-1)</definition>
    <parametric-curve function="__c" domain="(0, 2*pi)" stroke="magenta" cliptobbox="yes"/>
    <definition>__d(t) = (0.1*cos(t)+1.02, 2.02*sin(t)-1)</definition>
    <parametric-curve function="__d" domain="(0, 2*pi)" stroke="darkblue" cliptobbox="yes"/>
    <line endpoints="((-1,-1),(3,-1))" stroke="black" dash="2 2" cliptobbox="yes"/>
    <line endpoints="((1.5,-1),(1.5,0.25))" stroke="magenta" cliptobbox="yes"/>
    <line endpoints="((2.1,-1),(2.1,0.5))" stroke="red" cliptobbox="yes"/>
    <line endpoints="((0.4,0.5),(0.6,0.5))" stroke="red" cliptobbox="yes"/>
    <line endpoints="((0.4,-2.5),(0.6,-2.5))" stroke="red" cliptobbox="yes"/>
    <label anchor="(1.5,-0.5)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>r(x)</m></label>
    <label anchor="(2.1,-0.4)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>R(x)</m></label>
  </coordinates>
</diagram>
