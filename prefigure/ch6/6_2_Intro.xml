<diagram xmlns="https://prefigure.org"
         dimensions="(150,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-1,-3,4,3)">
    <grid spacings="((-1,5,4),(-3,6,3))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,3,3)" vlabels="(0,2,2)"/>
    <line endpoints="((0,2),(3,2))" stroke="darkblue"/>
    <line endpoints="((0,-2),(3,-2))" stroke="darkblue"/>
    <definition>__a(t) = (0.2*cos(t), 2*sin(t))</definition>
    <parametric-curve function="__a" domain="(0.5*pi, 1.5*pi)" stroke="darkblue"/>
    <definition>__b(t) = (0.2*cos(t)+3, 2*sin(t))</definition>
    <parametric-curve function="__b" domain="(0, 2*pi)" stroke="darkblue"/>
    <definition>__c(t) = (0.2*cos(t)+1, 2*sin(t))</definition>
    <parametric-curve function="__c" domain="(0.5*pi, 1.5*pi)" stroke="red"/>
    <definition>__d(t) = (0.2*cos(t)+1.2, 2*sin(t))</definition>
    <parametric-curve function="__d" domain="(0, 2*pi)" stroke="red"/>
    <line endpoints="((1,2),(1.2,2))" stroke="red"/>
    <line endpoints="((1,-2),(1.2,-2))" stroke="red"/>
    <line endpoints="((1.2,-0.1),(1.2,0.1))" stroke="black"/>
    <label anchor="(1.1,-2.3)" alignment="c"><m>\triangle x</m></label>
    <label anchor="(1.2,-0.4)" alignment="c"><m>x</m></label>
    <label anchor="(0.1,2.5)" alignment="ne" offset="(2,2)"><m>y</m></label>
  </coordinates>
</diagram>
