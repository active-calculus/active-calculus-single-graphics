<diagram xmlns="https://prefigure.org"
         dimensions="(150,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-1,-1,3,3)">
    <grid spacings="((-1,4,3),(-1,4,3))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f(x) = 0.5*cos(2.5*x) + 2</definition>
    <area-under-curve function="f" domain="(0.25,2.5)" fill="lightblue"/>
    <graph function="f" stroke="blue"/>
    <label anchor="(0.1,2.5)" alignment="ne" offset="(2,2)"><m>y = f(x)</m></label>
    <label anchor="(0.25,-0.35)" alignment="n" offset="(0,2)"><m>a</m></label>
    <label anchor="(2.5,-0.35)" alignment="n" offset="(0,2)"><m>b</m></label>
    <label anchor="(1.35,1)" alignment="c"><m>A = \int_a^b f(x) \, dx</m></label>
  </coordinates>
</diagram>
