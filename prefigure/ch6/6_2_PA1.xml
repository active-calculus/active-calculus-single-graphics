<diagram xmlns="https://prefigure.org"
         dimensions="(150,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-1,-4,6,4)">
    <grid spacings="((-1,7,6),(-4,8,4))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,5,5)" vlabels="(0,3,3)"/>
    <line endpoints="((0,3),(5,0))" stroke="darkblue"/>
    <line endpoints="((0,-3),(5,0))" stroke="darkblue"/>
    <definition>__a(t) = (0.4*cos(t), 3*sin(t))</definition>
    <parametric-curve function="__a" domain="(0.5*pi, 1.5*pi)" stroke="darkblue"/>
    <definition>__b(t) = (0.4*cos(t)+0.8, 2.4*sin(t))</definition>
    <parametric-curve function="__b" domain="(0.5*pi, 1.5*pi)" stroke="red"/>
    <definition>__c(t) = (0.4*cos(t)+1.2, 2.4*sin(t))</definition>
    <parametric-curve function="__c" domain="(0, 12*pi)" stroke="red"/>
    <line endpoints="((0.8,2.4),(1.2,2.4))" stroke="red"/>
    <line endpoints="((0.8,-2.4),(1.2,-2.4))" stroke="red"/>
    <line endpoints="((1.2,-0.2),(1.2,0.2))" stroke="black"/>
    <label anchor="(1.1,-2.9)" alignment="c"><m>\triangle x</m></label>
    <label anchor="(1.2,-0.4)" alignment="c"><m>x</m></label>
    <label anchor="(0.1,3.3)" alignment="ne" offset="(2,2)"><m>y</m></label>
    <label anchor="(3.1,1)" alignment="ne" offset="(3,4)"><m>y=f(x)</m></label>
  </coordinates>
</diagram>
