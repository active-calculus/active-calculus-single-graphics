<diagram xmlns="https://prefigure.org"
         dimensions="(300,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-0.25,-0.5,1.25,3)">
    <grid spacings="((-0.25,1.5,1.25),(-0.5,3.5,3))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f(x) = 1/sqrt(x)</definition>
    <area-under-curve function="f" domain="(0.2,1)" fill="lightblue"/>
    <graph function="f" domain="(0.1,1.25)" stroke="blue" cliptobbox="yes"/>
    <label anchor="(-0.125,2.5)" alignment="ne" offset="(2,2)"><m>y</m></label>
    <label anchor="(1.1,0.05)" alignment="ne" offset="(2,2)"><m>x</m></label>
    <label anchor="(0.5,1.414)" alignment="ne" offset="(2,2)"><m>f(x) = \frac{1}{\sqrt{x}}</m></label>
    <label anchor="(1,-0.3)" alignment="n" offset="(0,2)"><m>1</m></label>
    <label anchor="(0.2,-0.3)" alignment="n" offset="(0,2)"><m>a</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(-0.25,-0.5,1.25,3)">
    <definition>g(x) = 2.9999</definition>
    <area-under-curve function="g" domain="(0,0.11111)" fill="lightblue" cliptobbox="yes"/>
    <definition>f(x) = 1/sqrt(x)</definition>
    <area-under-curve function="f" domain="(0.11111,1)" fill="lightblue" cliptobbox="yes"/>
    <line endpoints="((0.11111,0),(0.11111,3))" stroke="lightblue" thickness="2"/>
    <line endpoints="((1,0),(1,1))" stroke="black"/>
    <graph function="f" domain="(0.1,1.25)" stroke="blue" cliptobbox="yes"/>
    <grid spacings="((-0.25,1.5,1.25),(-0.5,3.5,3))" stroke="lightgray"/>
    <axes decorations="no"/>
    <label anchor="(-0.125,2.5)" alignment="ne" offset="(2,2)"><m>y</m></label>
    <label anchor="(1.1,0.05)" alignment="ne" offset="(2,2)"><m>x</m></label>
    <label anchor="(0.5,1.414)" alignment="ne" offset="(2,2)"><m>f(x) = \frac{1}{\sqrt{x}}</m></label>
    <label anchor="(1,-0.3)" alignment="n" offset="(0,2)"><m>1</m></label>
  </coordinates>
</diagram>
