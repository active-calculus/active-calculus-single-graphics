<diagram xmlns="https://prefigure.org"
         dimensions="(450,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-1.5,-2,3.5,3)">
    <grid spacings="((-1.5,5,3.5),(-2,5,3))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,1,3)" vlabels="(-1,1,2)"/>
    <definition>f(x) = sqrt(x+1)</definition>
    <definition>g(x) = -sqrt(x+1)</definition>
    <definition>h(x) = x-1</definition>
    <area-under-curve function="f" lower="g" domain="(-0.9999,0)" fill="magenta"/>
    <area-under-curve function="f" lower="h" domain="(0,3)" fill="magenta"/>
    <line endpoints="((0,-1),(0,1))" stroke="magenta" thickness="2"/>
    <graph function="f" stroke="red" domain="(-0.9999,3.5)" cliptobbox="yes"/>
    <graph function="g" stroke="red" domain="(-0.9999,1)" cliptobbox="yes"/>
    <graph function="h" stroke="blue" cliptobbox="yes"/>
    <label anchor="(1,2)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>x=y^2-1</m></label>
    <label anchor="(1.5,0.5)" alignment="se" offset="(2,-2)" cliptobbox="yes"><m>y=x-1</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(-1.5,-2,3.5,3)">
    <grid spacings="((-1.5,5,3.5),(-2,5,3))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,1,3)" vlabels="(-1,1,2)"/>
    <definition>f(x) = sqrt(x+1)</definition>
    <definition>g(x) = -sqrt(x+1)</definition>
    <definition>h(x) = x-1</definition>
    <graph function="f" stroke="red" domain="(-0.9999,3.5)" cliptobbox="yes"/>
    <graph function="g" stroke="red" domain="(-0.9999,1)" cliptobbox="yes"/>
    <graph function="h" stroke="blue" cliptobbox="yes"/>
    <riemann-sum function="f" lower="g" N="1" domain="(-0.6,-0.4)" rule="midpoint" fill="lightgreen" cliptobbox="yes"/>
    <riemann-sum function="f" lower="h" N="1" domain="(1.1,1.3)" rule="midpoint" fill="lightgreen" cliptobbox="yes"/>
    <label anchor="(1,2)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>x=y^2-1</m></label>
    <label anchor="(0.5,-0.5)" alignment="se" offset="(2,-2)" cliptobbox="yes"><m>y=x-1</m></label>
  </coordinates>

  <coordinates destination="(310,10,440,140)"
               bbox="(-1.5,-2,3.5,3)">
    <grid spacings="((-1.5,5,3.5),(-2,5,3))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,1,3)" vlabels="(-1,1,2)"/>
    <definition>f(x) = sqrt(x+1)</definition>
    <definition>g(x) = -sqrt(x+1)</definition>
    <definition>h(x) = x-1</definition>
    <graph function="f" stroke="red" domain="(-0.9999,3.5)" cliptobbox="yes"/>
    <graph function="g" stroke="red" domain="(-0.9999,1)" cliptobbox="yes"/>
    <graph function="h" stroke="blue" cliptobbox="yes"/>
    <polygon points="((-0.5,0.6),(1.7,0.6),(1.7,0.8),(-0.5,0.8))" closed="yes" fill="lightgreen" stroke="black" cliptobbox="yes"/>
    <label anchor="(1,2)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>x=y^2-1</m></label>
    <label anchor="(0.5,-0.5)" alignment="se" offset="(2,-2)" cliptobbox="yes"><m>x = y+1</m></label>
    <label anchor="(1.7,0.7)" alignment="e" offset="(2,0)" cliptobbox="yes"><m>\triangle y</m></label>
  </coordinates>
</diagram>
