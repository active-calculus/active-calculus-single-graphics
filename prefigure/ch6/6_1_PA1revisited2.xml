<diagram xmlns="https://prefigure.org"
         dimensions="(300,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-0.5,-1,4,8)">
    <grid spacings="((-0.5,4.5,4),(-1,9,8))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f(x) = x**2 - 2*x + 2</definition>
    <definition>g(x) = x + 2</definition>
    <graph function="f" stroke="blue" cliptobbox="yes"/>
    <graph function="g" stroke="red" cliptobbox="yes"/>
    <riemann-sum function="f" lower="g" N="1" domain="(1.1,1.4)" rule="midpoint" fill="lightgreen" cliptobbox="yes"/>
    <label anchor="(0.25,2.5)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>g</m></label>
    <label anchor="(0.25,0.2)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>f</m></label>
    <label anchor="(1.25,-0.9)" alignment="n" offset="(0,2)" cliptobbox="yes"><m>x</m></label>
    <label anchor="(1.25,0)" alignment="n" offset="(0,2)" cliptobbox="yes"><m>\triangle x</m></label>
    <label anchor="(1.5,2.35)" alignment="e" offset="(2,0)" cliptobbox="yes"><m>g(x)-f(x)</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(-0.5,-1,4,8)">
    <grid spacings="((-0.5,4.5,4),(-1,9,8))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,1,3)" vlabels="(0,2,6)"/>
    <definition>f(x) = x**2 - 2*x + 2</definition>
    <definition>g(x) = x + 2</definition>
    <area-under-curve function="g" lower="f" domain="(0,3)" fill="magenta"/>
    <graph function="f" stroke="blue" cliptobbox="yes"/>
    <graph function="g" stroke="red" cliptobbox="yes"/>
    <label anchor="(0.25,0.3)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>f</m></label>
    <label anchor="(0.25,2.5)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>g</m></label>
  </coordinates>
</diagram>
