<diagram xmlns="https://prefigure.org"
         dimensions="(300,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-0.5,-0.5,3.5,3.5)">
    <grid spacings="((-0.5,0.5,3.5),(-0.5,0.5,3.5))" stroke="gainsboro"/>
    <axes decorations="no"/>
    <definition>f(x) = 0.5*sin(2*x) + 2.05</definition>
    <riemann-sum function="f" N="1" domain="(1.2,1.6)" rule="midpoint" fill="lightgreen"/>
    <graph function="f" stroke="blue" cliptobbox="yes"/>
    <label anchor="(0.1,3)" alignment="ne" offset="(2,2)" cliptobbox="yes">ft/sec</label>
    <label anchor="(3,0.1)" alignment="ne" offset="(2,2)" cliptobbox="yes">sec</label>
    <label anchor="(2.25,2.45)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>y= v(t)</m></label>
    <label anchor="(1.2,1.15)" alignment="w" offset="(-3,0)" cliptobbox="yes"><m>v(t)</m></label>
    <label anchor="(1.4,-0.3)" alignment="c" cliptobbox="yes"><m>\triangle t</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(-0.5,-0.5,3.5,3.5)">
    <grid spacings="((-0.5,0.5,3.5),(-0.5,0.5,3.5))" stroke="gainsboro"/>
    <axes decorations="no"/>
    <definition>f(x) = 1 + 0.3*x**2</definition>
    <riemann-sum function="f" N="1" domain="(1.2,1.6)" rule="midpoint" fill="lightgreen"/>
    <graph function="f" stroke="blue" cliptobbox="yes"/>
    <label anchor="(0.1,3)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>y</m></label>
    <label anchor="(3,0.1)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>x</m></label>
    <label anchor="(2.25,2.25)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>y= f(x)</m></label>
    <label anchor="(1.2,0.65)" alignment="w" offset="(-3,0)" cliptobbox="yes"><m>f(x)</m></label>
    <label anchor="(1.4,-0.3)" alignment="c" cliptobbox="yes"><m>\triangle x</m></label>
  </coordinates>
</diagram>
