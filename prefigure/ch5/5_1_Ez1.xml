<diagram xmlns="https://prefigure.org"
         dimensions="(300,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-0.5,-3.5,6.5,3.5)">
    <grid spacings="((-0.5,0.5,6.5),(-3.5,0.5,3.5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(1,5,6)" vlabels="(-3,3,3)"/>
    <definition>f(x) = -2 + 0.5*(x-3)**2</definition>
    <area-under-curve function="f" domain="(0,1)" fill="lightblue"/>
    <area-under-curve function="f" domain="(1,3)" fill="lightred"/>
    <graph function="f" stroke="blue" domain="(0,6)"/>
    <label anchor="(5.5,2)" alignment="nw" offset="(-2,2)"><m>v</m></label>
    <label anchor="(0.3,0.7)" alignment="c"><m>A_1</m></label>
    <label anchor="(2.2,-0.8)" alignment="c"><m>A_2</m></label>
    <label anchor="(6,0.4)" alignment="c"><m>t</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(-0.5,-3.5,6.5,3.5)">
    <grid spacings="((-0.5,0.5,6.5),(-3.5,0.5,3.5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,2,6)" vlabels="(-3,2,3)"/>
    <label anchor="(6,0.4)" alignment="c"><m>t</m></label>
    <label anchor="(0.4,3)" alignment="c"><m>s</m></label>
  </coordinates>
</diagram>
