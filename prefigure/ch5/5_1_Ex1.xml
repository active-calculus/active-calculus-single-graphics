<diagram xmlns="https://prefigure.org"
         dimensions="(300,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-1,-4,7,4)">
    <grid spacings="((-1,1,7),(-4,1,4))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(1,2,5)" vlabels="(-3,2,3)"/>
    <definition>f1(x) = 0</definition>
    <graph function="f1" stroke="darkgreen" domain="(-1,0)"/>
    <definition>f2(x) = x</definition>
    <graph function="f2" stroke="darkgreen" domain="(0,1)"/>
    <definition>f3(x) = 3 - 2*x</definition>
    <graph function="f3" stroke="darkgreen" domain="(1,3)"/>
    <definition>f4(x) = -3 + 3*(x-3)</definition>
    <graph function="f4" stroke="darkgreen" domain="(3,5)"/>
    <definition>f5(x) = 3 - 3*(x-5)</definition>
    <graph function="f5" stroke="darkgreen" domain="(5,6)"/>
    <definition>f6(x) = 0</definition>
    <graph function="f6" stroke="darkgreen" domain="(6,7)"/>
    <label anchor="(5,3)" alignment="ne" offset="(2,2)"><m>f</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(-1,-4,7,4)">
    <grid spacings="((-1,1,7),(-4,1,4))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,2,4)" vlabels="(-2,2,2)"/>
    <definition>F1(x) = 1</definition>
    <graph function="F1" stroke="blue" domain="(-1,0)"/>
    <definition>F2(x) = 1 + 0.5*x**2</definition>
    <graph function="F2" stroke="blue" domain="(0,1)"/>
    <definition>F3(x) = -0.5 + 3*x - x**2</definition>
    <graph function="F3" stroke="blue" domain="(1,3)"/>
    <definition>F4(x) = 8.5 - 3*x + 1.5*(x-3)**2</definition>
    <graph function="F4" stroke="blue" domain="(3,5)"/>
    <definition>F5(x) = -15.5 + 3*x - 1.5*(x-5)**2</definition>
    <graph function="F5" stroke="blue" domain="(5,6)"/>
    <definition>F6(x) = 1</definition>
    <graph function="F6" stroke="blue" domain="(6,7)"/>
    <definition>G1(x) = 3</definition>
    <graph function="G1" stroke="red" domain="(-1,0)"/>
    <definition>G2(x) = 3 + 0.5*x**2</definition>
    <graph function="G2" stroke="red" domain="(0,1)"/>
    <definition>G3(x) = 1.5 + 3*x - x**2</definition>
    <graph function="G3" stroke="red" domain="(1,3)"/>
    <definition>G4(x) = 10.5 - 3*x + 1.5*(x-3)**2</definition>
    <graph function="G4" stroke="red" domain="(3,5)"/>
    <definition>G5(x) = -13.5 + 3*x - 1.5*(x-5)**2</definition>
    <graph function="G5" stroke="red" domain="(5,6)"/>
    <definition>G6(x) = 3</definition>
    <graph function="G6" stroke="red" domain="(6,7)"/>
    <definition>H1(x) = -1</definition>
    <graph function="H1" stroke="magenta" domain="(-1,0)"/>
    <definition>H2(x) = -1 + 0.5*x**2</definition>
    <graph function="H2" stroke="magenta" domain="(0,1)"/>
    <definition>H3(x) = -2.5 + 3*x - x**2</definition>
    <graph function="H3" stroke="magenta" domain="(1,3)"/>
    <definition>H4(x) = 6.5 - 3*x + 1.5*(x-3)**2</definition>
    <graph function="H4" stroke="magenta" domain="(3,5)"/>
    <definition>H5(x) = -17.5 + 3*x - 1.5*(x-5)**2</definition>
    <graph function="H5" stroke="magenta" domain="(5,6)"/>
    <definition>H6(x) = -1</definition>
    <graph function="H6" stroke="magenta" domain="(6,7)"/>
    <label anchor="(6,1)" alignment="ne" offset="(2,4)"><m>F</m></label>
    <label anchor="(6,3)" alignment="ne" offset="(2,4)"><m>G</m></label>
    <label anchor="(6,-1)" alignment="ne" offset="(2,4)"><m>H</m></label>
  </coordinates>
</diagram>
