<diagram xmlns="https://prefigure.org"
         dimensions="(450,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-0.5,-0.5,2,2)">
    <axes decorations="no"/>
    <definition>f1(x) = 0.5 + 0.375*(x-2)**2</definition>
    <riemann-sum function="f1" N="1" domain="(0.5,1.5)" rule="trapezoidal" fill="lightgreen"/>
    <graph function="f1" stroke="blue" domain="(0.3,1.7)" cliptobbox="yes"/>
    <label anchor="(1,0.5)" alignment="c"><m>T_1</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(-0.5,-0.5,2,2)">
    <axes decorations="no"/>
    <definition>f2(x) = 0.5 + 0.375*(x-2)**2</definition>
    <riemann-sum function="f2" N="1" domain="(0.5,1.5)" rule="midpoint" fill="yellow"/>
    <graph function="f2" stroke="blue" domain="(0.3,1.7)" cliptobbox="yes"/>
    <line endpoints="((0.5,0.875),(1.5,0.875))" stroke="magenta"/>
    <label anchor="(1,0.5)" alignment="c"><m>M_1</m></label>
  </coordinates>

  <coordinates destination="(310,10,440,140)"
               bbox="(-0.5,-0.5,2,2)">
    <axes decorations="no"/>
    <definition>f3(x) = 0.5 + 0.375*(x-2)**2</definition>
    <graph function="f3" stroke="blue" domain="(0.3,1.7)" cliptobbox="yes"/>
    <polygon points="((0.5,0),(1.5,0),(1.5,0.5),(0.5,1.25))" closed="yes" fill="yellow" stroke="black"/>
    <line endpoints="((1.5,0.5),(1.5,0.875))" stroke="black"/>
    <line endpoints="((0.5,1.25),(1.5,0.5))" stroke="magenta"/>
    <line endpoints="((0.5,0.875),(1.5,0.875))" stroke="magenta"/>
    <label anchor="(1,0.5)" alignment="c"><m>M_1</m></label>
  </coordinates>
</diagram>
