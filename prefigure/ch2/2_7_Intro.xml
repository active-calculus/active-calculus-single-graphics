<diagram xmlns="https://prefigure.org"
         dimensions="(450,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-5,-5,5,5)">
    <grid spacings="((-5,1,5),(-5,1,5))" stroke="lightgray"/>
    <axes decorations="no"/>
    <circle center="(0,0)" radius="4" stroke="blue"/>
    <point p="(-3,sqrt(7))" size="2" fill="red"/>
    <point p="(-3,-sqrt(7))" size="2" fill="red"/>
    <rectangle lower-left="(1,1)" dimensions="(3,3)" stroke="gray"/>
    <label anchor="(-3,sqrt(7))" alignment="se" offset="(2,-2)"><m>A</m></label>
    <label anchor="(-3,-sqrt(7))" alignment="ne" offset="(2,4)"><m>B</m></label>
    <label anchor="(-4.6,4)" alignment="ne" offset="(2,2)"><m>x^2 + y^2 = 16</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(1,1,4,4)">
    <grid spacings="((1,1,4),(1,1,4))" stroke="lightgray"/>
    <definition>f(x) = sqrt(16-x**2)</definition>
    <graph function="f" stroke="blue" domain="(1,4)" cliptobbox="yes"/>
    <rectangle lower-left="(1,1)" dimensions="(3,3)" stroke="gray" cliptobbox="yes"/>
  </coordinates>

  <coordinates destination="(310,10,440,140)"
               bbox="(-5,-5,5,5)">
    <grid spacings="((-5,1,5),(-5,1,5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(-4,4,4)" vlabels="(-4,4,4)"/>
    <definition>f(x,y) = x*x*x - y*y*y - 6*x*y</definition>
    <implicit-curve function="f" value="0" stroke="blue"/>
    <label anchor="(0.2,3)" alignment="ne" offset="(2,2)"><m>x^3 - y^3 = 6xy</m></label>
    <label anchor="(4.2,0.2)" alignment="ne" offset="(2,2)"><m>x</m></label>
  </coordinates>
</diagram>
