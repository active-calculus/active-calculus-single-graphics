<diagram xmlns="https://prefigure.org"
         dimensions="(480,80)">
  <coordinates destination="(10,10,230,70)"
               bbox="(-2*pi,-2,2*pi,2)">
    <grid spacings="((-2*pi,pi/2,2*pi),(-2,1,2))" stroke="lightgray"/>
    <axes decorations="no" vlabels="(-1,1,1)"/>
    <label anchor="(-2*pi,-0.4)" alignment="s" offset="(2,2)"><m>-2\pi</m></label>
    <label anchor="(-pi,-0.4)" alignment="s" offset="(-2,2)"><m>-\pi</m></label>
    <label anchor="(pi,-0.5)" alignment="s" offset="(2,2)"><m>\pi</m></label>
    <label anchor="(2*pi,-0.4)" alignment="s" offset="(0,2)"><m>2\pi</m></label>
    <definition>f(x) = cos(x)</definition>
    <graph function="f" stroke="blue" cliptobbox="yes"/>
  </coordinates>

  <coordinates destination="(250,10,470,70)"
               bbox="(-2*pi,-2,2*pi,2)">
    <grid spacings="((-2*pi,pi/2,2*pi),(-2,1,2))" stroke="lightgray"/>
    <axes decorations="no" vlabels="(-1,1,1)"/>
    <label anchor="(-2*pi,-0.4)" alignment="s" offset="(2,2)"><m>-2\pi</m></label>
    <label anchor="(-pi,-0.4)" alignment="s" offset="(-2,2)"><m>-\pi</m></label>
    <label anchor="(pi,-0.5)" alignment="s" offset="(2,2)"><m>\pi</m></label>
    <label anchor="(2*pi,-0.4)" alignment="s" offset="(0,2)"><m>2\pi</m></label>
  </coordinates>
</diagram>
