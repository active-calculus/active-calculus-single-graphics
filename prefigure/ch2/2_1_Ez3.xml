<diagram xmlns="https://prefigure.org"
         dimensions="(150,150)">
  <coordinates destination="(5,5,145,145)"
               bbox="(-3.5,-3.5,3.5,3.5)">
    <grid spacings="((-3.5,0.5,3.5),(-3.5,0.5,3.5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(-3,1,3)" vlabels="(-3,1,3)"/>
    <label anchor="(-2.75,3)"><m>p</m></label>
    <label anchor="(-2.75,-2)"><m>q</m></label>
    <definition>f1(x) = -2*x-3</definition>
    <graph function="f1" stroke="blue" domain="(-3.5,-1)" cliptobbox="yes"/>
    <definition>f2(x) = 0.5*(x+1)-1</definition>
    <graph function="f2" stroke="blue" domain="(-1,1)" cliptobbox="yes"/>
    <definition>f3(x) = 2*(x-1)</definition>
    <graph function="f3" stroke="blue" domain="(1,3.5)" cliptobbox="yes"/>
    <definition>f4(x) = 3*(x+2)-1</definition>
    <graph function="f4" stroke="darkgreen" domain="(-3.5,-1)" cliptobbox="yes"/>
    <definition>f5(x) = 2</definition>
    <graph function="f5" stroke="darkgreen" domain="(-1,1)" cliptobbox="yes"/>
    <definition>f6(x) = 2-(x-1)</definition>
    <graph function="f6" stroke="darkgreen" domain="(1,3.5)" cliptobbox="yes"/>
  </coordinates>
</diagram>
