<diagram xmlns="https://prefigure.org"
         dimensions="(300,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-0.5,-2.5,4.5,2.5)">
    <grid spacings="((-0.5,0.5,4.5),(-2.5,0.5,2.5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,1,4)" vlabels="(-2,1,2)"/>
    <definition>f1(x) = 0.5*(x**2-4)</definition>
    <graph function="f1" stroke="darkblue" domain="(-0.5,4.5)" cliptobbox="yes"/>
    <tangent-line function="f1" point="2" domain="(0.6,3.4)" stroke="darkgreen" cliptobbox="yes"/>
    <definition>f2(x) = 0.25*(4-x**2)</definition>
    <graph function="f2" stroke="lightblue" domain="(-0.5,4.5)" cliptobbox="yes"/>
    <tangent-line function="f2" point="2" domain="(0.6,3.4)" stroke="green" cliptobbox="yes"/>
    <point p="(2,0)" size="1.25" fill="red" cliptobbox="yes"/>
    <rectangle lower-left="(1.5,-0.5)" dimensions="(1,1)" stroke="gray" cliptobbox="yes"/>
    <label anchor="(2,-0.1)" alignment="s" offset="(0,-2)" cliptobbox="yes"><m>a</m></label>
    <label anchor="(3,-1.5)" alignment="sw" offset="(0,0)" cliptobbox="yes"><m>g</m></label>
    <label anchor="(2.6,-0.7)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>m = g'(a)</m></label>
    <label anchor="(2.5,2)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>f</m></label>
    <label anchor="(2.5,0.5)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>m = f'(a)</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(1.5,-0.5,2.5,0.5)">
    <axes decorations="no"/>
    <definition>f1(x) = 0.5*(x**2-4)</definition>
    <graph function="f1" stroke="darkblue" domain="(1.5,2.5)" cliptobbox="yes"/>
    <tangent-line function="f1" point="2" domain="(1.5,2.5)" stroke="darkgreen" cliptobbox="yes"/>
    <definition>f2(x) = 0.25*(4-x**2)</definition>
    <graph function="f2" stroke="lightblue" domain="(1.5,2.5)" cliptobbox="yes"/>
    <tangent-line function="f2" point="2" domain="(1.5,2.5)" stroke="green" cliptobbox="yes"/>
    <point p="(2,0)" size="2" fill="red" cliptobbox="yes"/>
    <rectangle lower-left="(1.5,-0.5)" dimensions="(1,1)" stroke="gray" cliptobbox="yes"/>
    <label anchor="(2,-0.05)" alignment="s" offset="(0,-1)" cliptobbox="yes"><m>a</m></label>
    <label anchor="(2.15,-0.15)" alignment="ne" offset="(0,0)" cliptobbox="yes"><m>m = g'(a)</m></label>
    <label anchor="(2.15,0.2)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>m = f'(a)</m></label>
  </coordinates>
</diagram>
