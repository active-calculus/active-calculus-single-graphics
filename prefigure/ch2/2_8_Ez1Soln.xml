<diagram xmlns="https://prefigure.org"
         dimensions="(150,150)">
  <coordinates destination="(5,5,145,145)"
               bbox="(0.5,-2.5,5.5,2.5)">
    <grid spacings="((0.5,0.5,5.5),(-2.5,0.5,2.5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(1,1,5)" vlabels="(-2,1,2)"/>
    <definition>f1(x) = -1*(x-3)**2</definition>
    <graph function="f1" stroke="darkblue" domain="(0.5,5.5)" cliptobbox="yes"/>
    <definition>f2(x) = 0.5*(x-3)**2</definition>
    <graph function="f2" stroke="lightblue" domain="(0.5,5.5)" cliptobbox="yes"/>
    <tangent-line function="f2" point="3" domain="(1.6,4.4)" stroke="darkgreen" cliptobbox="yes"/>
    <point p="(3,0)" size="2" fill="red" cliptobbox="yes"/>
    <label anchor="(3,-1)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>f</m></label>
    <label anchor="(3,0.5)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>g</m></label>
  </coordinates>
</diagram>
