<diagram xmlns="https://prefigure.org"
         dimensions="(150,150)">
  <coordinates destination="(5,5,145,145)"
               bbox="(-5,-1,7,9)">
    <grid spacings="((-5,12,7),(-1,10,9))" stroke="lightgray"/>
    <axes decorations="no"/>
    <line endpoints="((-5,8),(7,8))" stroke="gray" thickness="1"/>
    <definition>f(x) = 8/(1 + 3.0*exp(-0.7*x))</definition>
    <graph function="f" stroke="blue" domain="(-5,7)" cliptobbox="yes"/>
    <label anchor="(0.3,6.5)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>y = L(x)</m></label>
    <label anchor="(6.5,8)" alignment="nw" offset="(-2,2)" cliptobbox="yes"><m>y = A</m></label>
    <label anchor="(6.5,0)" alignment="nw" offset="(-2,2)" cliptobbox="yes"><m>y = 0</m></label>
    <point p="(0,f(0))" size="2" fill="red" cliptobbox="yes"/>
    <label anchor="(0,f(0))" alignment="nw" offset="(-4,2)" cliptobbox="yes"><m>(0, \frac{A}{1+c})</m></label>
    <point p="(-log(1/3)/0.7,4)" size="2" fill="red" cliptobbox="yes"/>
    <label anchor="(-log(1/3)/0.7,4)" alignment="se" offset="(2,-2)" cliptobbox="yes"><m>(-\frac{1}{k} \ln(\frac{1}{c}), \frac{A}{2})</m></label>
  </coordinates>
</diagram>
