<diagram xmlns="https://prefigure.org"
         dimensions="(480,120)">
  <coordinates destination="(5,5,115,115)"
               bbox="(-1,-1,5,5)">
    <axes decorations="no"/>
    <grid spacings="((-1,6,5),(-1,6,5))" stroke="lightgray"/>
    <definition>f(x) = -0.5*(x-2)**2 + 2</definition>
    <graph function="f" stroke="blue" domain="(-1,5)" cliptobbox="yes"/>
    <tangent-line function="f" point="2" domain="(0.8,3.2)" stroke="darkgreen" cliptobbox="yes"/>
    <point p="(2,f(2))" size="2" fill="red" cliptobbox="yes"/>
  </coordinates>

