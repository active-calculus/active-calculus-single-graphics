<diagram xmlns="https://prefigure.org"
         dimensions="(450,90)">
  <coordinates destination="(5,5,85,85)"
               bbox="(-1,-1,5,5)">
    <axes decorations="no"/>
    <grid spacings="((-1,6,5),(-1,6,5))" stroke="lightgray"/>
    <definition>f(x) = -0.5*(x-2)**2 + 2</definition>
    <graph function="f" stroke="blue" domain="(-1,5)" cliptobbox="yes"/>
    <tangent-line function="f" point="2" domain="(0.8,3.2)" stroke="darkgreen" cliptobbox="yes"/>
    <point p="(2,f(2))" size="2" fill="red" cliptobbox="yes"/>
  </coordinates>

  <coordinates destination="(95,5,175,85)"
               bbox="(-1,-1,5,5)">
    <axes decorations="no"/>
    <grid spacings="((-1,6,5),(-1,6,5))" stroke="lightgray"/>
    <definition>f1(x) = 0.3*(x+1)**2 - 0.6</definition>
    <graph function="f1" stroke="blue" domain="(-1,2)" cliptobbox="yes"/>
    <definition>f2(x) = 0.3*(x-5)**2 - 0.6</definition>
    <graph function="f2" stroke="blue" domain="(2,5)" cliptobbox="yes"/>
  </coordinates>

  <coordinates destination="(185,5,265,85)"
               bbox="(-1,-1,5,5)">
    <axes decorations="no"/>
    <grid spacings="((-1,6,5),(-1,6,5))" stroke="lightgray"/>
    <definition>f(x) = 0.5*(x-2)**3 + 2</definition>
    <graph function="f" stroke="blue" domain="(-1,5)" cliptobbox="yes"/>
    <tangent-line function="f" point="2" domain="(0.8,3.2)" stroke="darkgreen" cliptobbox="yes"/>
    <point p="(2,f(2))" size="2" fill="red" cliptobbox="yes"/>
  </coordinates>

  <coordinates destination="(275,5,355,85)"
               bbox="(-1,-1,5,5)">
    <axes decorations="no"/>
    <grid spacings="((-1,6,5),(-1,6,5))" stroke="lightgray"/>
    <definition>f(x) = 0.5*(x-2)**2 + 2</definition>
    <graph function="f" stroke="blue" domain="(-1,5)" cliptobbox="yes"/>
    <tangent-line function="f" point="2" domain="(0.8,3.2)" stroke="darkgreen" cliptobbox="yes"/>
    <point p="(2,f(2))" size="2" fill="red" cliptobbox="yes"/>
  </coordinates>

  <coordinates destination="(365,5,445,85)"
               bbox="(-1,-1,5,5)">
    <axes decorations="no"/>
    <grid spacings="((-1,6,5),(-1,6,5))" stroke="lightgray"/>
    <definition>f1(x) = -0.3*(x+1)**2 + 4.6</definition>
    <graph function="f1" stroke="blue" domain="(-1,2)" cliptobbox="yes"/>
    <definition>f2(x) = -0.3*(x-5)**2 + 4.6</definition>
    <graph function="f2" stroke="blue" domain="(2,5)" cliptobbox="yes"/>
  </coordinates>
</diagram>
