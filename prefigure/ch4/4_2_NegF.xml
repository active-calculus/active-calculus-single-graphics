<diagram xmlns="https://prefigure.org"
         dimensions="(450,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-1,-1,3,2)">
    <grid spacings="((-1,4,3),(-1,3,2))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f1(x) = cos(2.5*x) + 0.5</definition>
    <riemann-sum function="f1" N="12" domain="(0.2,2.8)" rule="left" fill="lightgreen"/>
    <graph function="f1" stroke="blue"/>
    <label anchor="(0.1,1.5)" alignment="ne" offset="(2,2)"><m>y = f(x)</m></label>
    <line endpoints="((0.1,-0.6),(2.9,-0.6))" stroke="black" thickness="1"/>
    <line endpoints="((0.2,-0.55),(0.2,-0.65))" stroke="black" thickness="1"/>
    <label anchor="(0.2,-0.95)" alignment="n" offset="(0,2)"><m>a</m></label>
    <line endpoints="((0.838,-0.55),(0.838,-0.65))" stroke="black" thickness="1"/>
    <label anchor="(0.838,-0.95)" alignment="n" offset="(0,2)"><m>b</m></label>
    <line endpoints="((1.676,-0.55),(1.676,-0.65))" stroke="black" thickness="1"/>
    <label anchor="(1.676,-0.95)" alignment="n" offset="(0,2)"><m>c</m></label>
    <line endpoints="((2.8,-0.55),(2.8,-0.65))" stroke="black" thickness="1"/>
    <label anchor="(2.8,-0.95)" alignment="n" offset="(0,2)"><m>d</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(-1,-1,3,2)">
    <grid spacings="((-1,4,3),(-1,3,2))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f2(x) = cos(2.5*x) + 0.5</definition>
    <riemann-sum function="f2" N="24" domain="(0.2,2.8)" rule="left" fill="lightgreen"/>
    <graph function="f2" stroke="blue"/>
    <label anchor="(0.1,1.5)" alignment="ne" offset="(2,2)"><m>y = f(x)</m></label>
    <line endpoints="((0.1,-0.6),(2.9,-0.6))" stroke="black" thickness="1"/>
    <line endpoints="((0.2,-0.55),(0.2,-0.65))" stroke="black" thickness="1"/>
    <label anchor="(0.2,-0.95)" alignment="n" offset="(0,2)"><m>a</m></label>
    <line endpoints="((0.838,-0.55),(0.838,-0.65))" stroke="black" thickness="1"/>
    <label anchor="(0.838,-0.95)" alignment="n" offset="(0,2)"><m>b</m></label>
    <line endpoints="((1.676,-0.55),(1.676,-0.65))" stroke="black" thickness="1"/>
    <label anchor="(1.676,-0.95)" alignment="n" offset="(0,2)"><m>c</m></label>
    <line endpoints="((2.8,-0.55),(2.8,-0.65))" stroke="black" thickness="1"/>
    <label anchor="(2.8,-0.95)" alignment="n" offset="(0,2)"><m>d</m></label>
  </coordinates>

  <coordinates destination="(310,10,440,140)"
               bbox="(-1,-1,3,2)">
    <grid spacings="((-1,4,3),(-1,3,2))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f3(x) = cos(2.5*x) + 0.5</definition>
    <definition>a3 = intersect((f3, 0), 1, (-1, 3))</definition>
    <definition>b3 = intersect((f3, 0), 1.7, (-1, 3))</definition>
    <area-under-curve function="f3" domain="(0.2, a3)" fill="lightblue"/>
    <area-under-curve function="f3" domain="(a3, b3)" fill="red"/>
    <area-under-curve function="f3" domain="(b3, 2.8)" fill="lightblue"/>
    <graph function="f3" stroke="blue"/>
    <label anchor="(0.1,1.5)" alignment="ne" offset="(2,2)"><m>y = f(x)</m></label>
    <label anchor="(0.42,0.5)" alignment="c"><m>A_1</m></label>
    <label anchor="(1.25,-0.2)" alignment="c"><m>A_2</m></label>
    <label anchor="(2.35,0.5)" alignment="c"><m>A_3</m></label>
    <line endpoints="((0.1,-0.6),(2.9,-0.6))" stroke="black" thickness="1"/>
    <line endpoints="((0.2,-0.55),(0.2,-0.65))" stroke="black" thickness="1"/>
    <label anchor="(0.2,-0.95)" alignment="n" offset="(0,2)"><m>a</m></label>
    <line endpoints="((0.838,-0.55),(0.838,-0.65))" stroke="black" thickness="1"/>
    <label anchor="(0.838,-0.95)" alignment="n" offset="(0,2)"><m>b</m></label>
    <line endpoints="((1.676,-0.55),(1.676,-0.65))" stroke="black" thickness="1"/>
    <label anchor="(1.676,-0.95)" alignment="n" offset="(0,2)"><m>c</m></label>
    <line endpoints="((2.8,-0.55),(2.8,-0.65))" stroke="black" thickness="1"/>
    <label anchor="(2.8,-0.95)" alignment="n" offset="(0,2)"><m>d</m></label>
  </coordinates>
</diagram>
