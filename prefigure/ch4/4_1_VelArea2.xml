    <label anchor="(0.1,3)" alignment="ne" offset="(2,2)">mph</label>
    <label anchor="(3,0.1)" alignment="ne" offset="(2,2)">hrs</label>
    <label anchor="(2.25,2.45)" alignment="ne" offset="(2,2)"><m>y= v(t)</m></label>
  </coordinates>
