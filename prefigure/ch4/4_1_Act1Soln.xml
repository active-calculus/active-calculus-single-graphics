<diagram xmlns="https://prefigure.org"
         dimensions="(120,160)">
  <coordinates destination="(10,10,110,150)"
               bbox="(-0.5,-0.5,2.5,3.5)">
    <grid spacings="((-0.5,0.25,2.5),(-0.5,0.25,3.5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(1,1,2)" vlabels="(1,1,3)"/>
    <definition>f(x) = 0.5*(x-1)**3 + 2</definition>
    <riemann-sum function="f" N="4" domain="(0,2)" rule="left" fill="lightgreen"/>
    <graph function="f" stroke="blue" domain="(-0.25,2.25)" cliptobbox="yes"/>
    <label anchor="(0.1,3)" alignment="ne" offset="(2,2)" cliptobbox="yes">mph</label>
    <label anchor="(2,0.1)" alignment="ne" offset="(2,2)" cliptobbox="yes">hrs</label>
    <label anchor="(2,2.5)" alignment="nw" offset="(-2,2)" cliptobbox="yes"><m>y= v(t)</m></label>
  </coordinates>
</diagram>
