<diagram xmlns="https://prefigure.org"
         dimensions="(150,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-0.5,-2.5,4.5,2.5)">
    <grid spacings="((-0.5,0.5,4.5),(-2.5,0.5,2.5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(1,1,4)" vlabels="(-2,1,2)"/>
    <definition>f1(x) = 1 - 2*x</definition>
    <graph function="f1" stroke="blue" domain="(0,1.5)"/>
    <definition>f2(x) = -2 + (x-1.5)</definition>
    <graph function="f2" stroke="blue" domain="(1.5,4)"/>
    <label anchor="(0.1,2)" alignment="ne" offset="(2,0)">ft/sec</label>
    <label anchor="(4,0.1)" alignment="ne" offset="(2,2)">sec</label>
    <label anchor="(4,-1)" alignment="sw" offset="(-2,-2)"><m>y = v(t)</m></label>
  </coordinates>
</diagram>
