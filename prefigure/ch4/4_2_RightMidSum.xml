<diagram xmlns="https://prefigure.org"
         dimensions="(450,150)">
  <coordinates destination="(10,10,215,140)"
               bbox="(-1,-2,9,12)">
    <axes decorations="no"/>
    <definition>f1(x) = -0.05*(x-4)**3 + 7</definition>
    <riemann-sum function="f1" N="2" domain="(1,3)" rule="right" fill="lightgreen"/>
    <riemann-sum function="f1" N="1" domain="(4.5,5.5)" rule="right" fill="lightgreen"/>
    <riemann-sum function="f1" N="1" domain="(7,8)" rule="right" fill="lightgreen"/>
    <graph function="f1" stroke="blue" cliptobbox="yes"/>
    <line endpoints="((1,-0.25),(1,0.25))" stroke="black" thickness="1" cliptobbox="yes"/>
    <label anchor="(1,-0.25)" alignment="s" offset="(0,-3)" cliptobbox="yes"><m>x_0</m></label>
    <line endpoints="((2,-0.25),(2,0.25))" stroke="black" thickness="1" cliptobbox="yes"/>
    <label anchor="(2,-0.25)" alignment="s" offset="(0,-3)" cliptobbox="yes"><m>x_1</m></label>
    <label anchor="(3,-0.25)" alignment="s" offset="(0,-3)" cliptobbox="yes"><m>x_2</m></label>
    <line endpoints="((4.5,-0.25),(4.5,0.25))" stroke="black" thickness="1" cliptobbox="yes"/>
    <label anchor="(4.5,-0.25)" alignment="s" offset="(0,-3)" cliptobbox="yes"><m>x_i</m></label>
    <line endpoints="((5.5,-0.25),(5.5,0.25))" stroke="black" thickness="1" cliptobbox="yes"/>
    <label anchor="(5.5,-0.25)" alignment="s" offset="(0,-3)" cliptobbox="yes"><m>x_{i+1}</m></label>
    <line endpoints="((7,-0.25),(7,0.25))" stroke="black" thickness="1" cliptobbox="yes"/>
    <label anchor="(7,-0.25)" alignment="s" offset="(0,-3)" cliptobbox="yes"><m>x_{n-1}</m></label>
    <line endpoints="((8,-0.25),(8,0.25))" stroke="black" thickness="1" cliptobbox="yes"/>
    <label anchor="(8,-0.25)" alignment="s" offset="(0,-3)" cliptobbox="yes"><m>x_{n}</m></label>
    <point p="(2,7.4)" size="1.5" fill="blue" cliptobbox="yes"/>
    <point p="(3,7.05)" size="1.5" fill="blue" cliptobbox="yes"/>
    <point p="(5.5,6.831)" size="1.5" fill="blue" cliptobbox="yes"/>
    <point p="(8,3.8)" size="1.5" fill="blue" cliptobbox="yes"/>
    <label anchor="(1.5,3)" alignment="c" cliptobbox="yes"><m>B_1</m></label>
    <label anchor="(2.5,3)" alignment="c" cliptobbox="yes"><m>B_2</m></label>
    <label anchor="(3.75,3)" alignment="c" cliptobbox="yes"><m>\cdots</m></label>
    <label anchor="(5,3)" alignment="c" cliptobbox="yes"><m>B_{i+1}</m></label>
    <label anchor="(6.25,3)" alignment="c" cliptobbox="yes"><m>\cdots</m></label>
    <label anchor="(7.5,3)" alignment="c" cliptobbox="yes"><m>B_n</m></label>
    <label anchor="(0.1,9.97)" alignment="ne" offset="(3,3)" cliptobbox="yes"><m>y = f(x)</m></label>
  </coordinates>

  <coordinates destination="(235,10,440,140)"
               bbox="(-1,-2,9,12)">
    <axes decorations="no"/>
    <definition>f2(x) = -0.05*(x-4)**3 + 7</definition>
    <riemann-sum function="f2" N="2" domain="(1,3)" rule="midpoint" fill="lightgreen"/>
    <riemann-sum function="f2" N="1" domain="(4.5,5.5)" rule="midpoint" fill="lightgreen"/>
    <riemann-sum function="f2" N="1" domain="(7,8)" rule="midpoint" fill="lightgreen"/>
    <graph function="f2" stroke="blue" cliptobbox="yes"/>
    <line endpoints="((1,-0.25),(1,0.25))" stroke="black" thickness="1" cliptobbox="yes"/>
    <label anchor="(1,-0.25)" alignment="s" offset="(0,-3)" cliptobbox="yes"><m>x_0</m></label>
    <line endpoints="((2,-0.25),(2,0.25))" stroke="black" thickness="1" cliptobbox="yes"/>
    <label anchor="(2,-0.25)" alignment="s" offset="(0,-3)" cliptobbox="yes"><m>x_1</m></label>
    <label anchor="(3,-0.25)" alignment="s" offset="(0,-3)" cliptobbox="yes"><m>x_2</m></label>
    <line endpoints="((4.5,-0.25),(4.5,0.25))" stroke="black" thickness="1" cliptobbox="yes"/>
    <label anchor="(4.5,-0.25)" alignment="s" offset="(0,-3)" cliptobbox="yes"><m>x_i</m></label>
    <line endpoints="((5.5,-0.25),(5.5,0.25))" stroke="black" thickness="1" cliptobbox="yes"/>
    <label anchor="(5.5,-0.25)" alignment="s" offset="(0,-3)" cliptobbox="yes"><m>x_{i+1}</m></label>
    <line endpoints="((7,-0.25),(7,0.25))" stroke="black" thickness="1" cliptobbox="yes"/>
    <label anchor="(7,-0.25)" alignment="s" offset="(0,-3)" cliptobbox="yes"><m>x_{n-1}</m></label>
    <line endpoints="((8,-0.25),(8,0.25))" stroke="black" thickness="1" cliptobbox="yes"/>
    <label anchor="(8,-0.25)" alignment="s" offset="(0,-3)" cliptobbox="yes"><m>x_{n}</m></label>
    <point p="(1.5,7.781)" size="1.5" fill="blue" cliptobbox="yes"/>
    <point p="(2.5,7.169)" size="1.5" fill="blue" cliptobbox="yes"/>
    <point p="(5,6.95)" size="1.5" fill="blue" cliptobbox="yes"/>
    <point p="(7.5,4.856)" size="1.5" fill="blue" cliptobbox="yes"/>
    <label anchor="(1.5,3)" alignment="c" cliptobbox="yes"><m>C_1</m></label>
    <label anchor="(2.5,3)" alignment="c" cliptobbox="yes"><m>C_2</m></label>
    <label anchor="(3.75,3)" alignment="c" cliptobbox="yes"><m>\cdots</m></label>
    <label anchor="(5,3)" alignment="c" cliptobbox="yes"><m>C_{i+1}</m></label>
    <label anchor="(6.25,3)" alignment="c" cliptobbox="yes"><m>\cdots</m></label>
    <label anchor="(7.5,3)" alignment="c" cliptobbox="yes"><m>C_n</m></label>
    <label anchor="(0.1,9.97)" alignment="ne" offset="(3,3)" cliptobbox="yes"><m>y = f(x)</m></label>
  </coordinates>
</diagram>
