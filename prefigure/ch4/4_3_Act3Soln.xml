<diagram xmlns="https://prefigure.org"
         dimensions="(150,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-0.5,-0.5,4.5,4.5)">
    <grid spacings="((-0.5,5,4.5),(-0.5,5,4.5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(0,2,4)" vlabels="(0,2,4)"/>
    <definition>f1(x) = sqrt(4 - (x-2)**2)</definition>
    <area-under-curve function="f1" domain="(0.001,3.999)" fill="lightblue"/>
    <definition>f2(x) = pi/2</definition>
    <area-under-curve function="f2" domain="(0,4)" fill="lightgreen"/>
    <graph function="f2" stroke="darkgreen"/>
    <graph function="f1" stroke="blue" domain="(0.001,3.999)"/>
    <label anchor="(3,2)" alignment="nw" offset="(-2,2)"><m>y = v(t)</m></label>
  </coordinates>
</diagram>
