<diagram xmlns="https://prefigure.org"
         dimensions="(300,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-0.5,-4.5,8.5,4.5)">
    <grid spacings="((-0.5,0.5,8.5),(-4.5,0.5,4.5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(2,2,8)" vlabels="(-4,2,4)"/>
    <definition>f1(x) = 2 - 2*x</definition>
    <graph function="f1" stroke="blue" domain="(0,2)"/>
    <definition>f2(x) = -2</definition>
    <graph function="f2" stroke="blue" domain="(2,3)"/>
    <definition>f3(x) = -2 + 2*(x-3)</definition>
    <graph function="f3" stroke="blue" domain="(3,6)"/>
    <definition>f4(x) = 4 - 2*(x-6)</definition>
    <graph function="f4" stroke="blue" domain="(6,8)"/>
    <label anchor="(0.25,4)" alignment="ne" offset="(2,0)">m/sec</label>
    <label anchor="(8,0.25)" alignment="ne" offset="(2,2)">sec</label>
    <label anchor="(6.5,3)" alignment="ne" offset="(2,2)"><m>y = v(t)</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(-0.5,-9,8.5,9)">
    <grid spacings="((-0.5,0.5,8.5),(-9,1,9))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(2,2,8)" vlabels="(-8,4,8)"/>
  </coordinates>
</diagram>
