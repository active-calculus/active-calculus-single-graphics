<diagram xmlns="https://prefigure.org"
         dimensions="(150,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-1,-1,3,3)">
    <grid spacings="((-1,4,3),(-1,4,3))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f(x) = sin(2*x) + x</definition>
    <area-under-curve function="f" domain="(0.2,1)" fill="lightblue"/>
    <area-under-curve function="f" domain="(1,2.4)" fill="lightred"/>
    <graph function="f" stroke="blue" cliptobbox="yes"/>
    <label anchor="(0.1,2)" alignment="ne" offset="(2,2)" cliptobbox="yes"><m>y = f(x)</m></label>
    <label anchor="(0.6,0.5)" alignment="c" cliptobbox="yes"><m>A_1</m></label>
    <label anchor="(1.6,0.5)" alignment="c" cliptobbox="yes"><m>A_2</m></label>
    <label anchor="(0.2,-0.4)" alignment="n" offset="(0,2)" cliptobbox="yes"><m>a</m></label>
    <label anchor="(1,-0.4)" alignment="n" offset="(0,2)" cliptobbox="yes"><m>b</m></label>
    <label anchor="(2.4,-0.4)" alignment="n" offset="(0,2)" cliptobbox="yes"><m>c</m></label>
  </coordinates>
</diagram>
