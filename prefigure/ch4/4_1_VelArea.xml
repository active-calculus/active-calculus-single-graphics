<diagram xmlns="https://prefigure.org"
         dimensions="(300,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-0.5,-0.5,3.5,3.5)">
    <grid spacings="((-0.5,0.5,3.5),(-0.5,0.5,3.5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(1,1,3)" vlabels="(1,2,3)"/>
    <definition>f1(x) = 2</definition>
    <riemann-sum function="f1" N="1" domain="(1,1.5)" rule="midpoint" fill="lightgreen"/>
    <graph function="f1" stroke="blue"/>
    <label anchor="(0.1,3)" alignment="ne" offset="(2,2)">mph</label>
    <label anchor="(3,0.1)" alignment="ne" offset="(2,2)">hrs</label>
    <label anchor="(2,2)" alignment="ne" offset="(2,2)"><m>v(t) = 2</m></label>
    <label anchor="(1.25,1)" alignment="c"><m>A_1</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(-0.5,-0.5,3.5,3.5)">
    <grid spacings="((-0.5,0.5,3.5),(-0.5,0.5,3.5))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(1,1,3)" vlabels="(1,2,3)"/>
    <definition>f2(x) = 0.5*sin(2*x) + 2.05</definition>
    <riemann-sum function="f2" N="1" domain="(1,1.5)" rule="left" fill="lightgreen"/>
    <graph function="f2" stroke="blue"/>
    <label anchor="(0.1,3)" alignment="ne" offset="(2,2)">mph</label>
    <label anchor="(3,0.1)" alignment="ne" offset="(2,2)">hrs</label>
    <label anchor="(2.25,2.45)" alignment="ne" offset="(2,2)"><m>y= v(t)</m></label>
    <label anchor="(1.25,1.25)" alignment="c"><m>A_2</m></label>
  </coordinates>
</diagram>
