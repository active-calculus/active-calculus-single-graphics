<diagram xmlns="https://prefigure.org"
         dimensions="(300,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-0.5,-0.5,3.5,4.5)">
    <grid spacings="((-0.5,4,3.5),(-0.5,5,4.5))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f1(x) = 0.5*sin(2*x) + 1.25</definition>
    <area-under-curve function="f1" domain="(0.2,2.8)" fill="lightblue"/>
    <riemann-sum function="f1" N="1" domain="(1,1.6)" rule="left" fill="lightgreen"/>
    <graph function="f1" stroke="blue"/>
    <label anchor="(0.2,-0.45)" alignment="n" offset="(0,2)"><m>a</m></label>
    <label anchor="(1,-0.5)" alignment="n" offset="(0,2)"><m>x_i</m></label>
    <label anchor="(1.3,2.1)" alignment="c"><m>A = f(x_i) \triangle x</m></label>
    <label anchor="(1.3,0.85)" alignment="c"><m>A</m></label>
    <label anchor="(1.6,-0.4)" alignment="n" offset="(2,-2)"><m>x_{i+1}</m></label>
    <label anchor="(2.8,-0.45)" alignment="n" offset="(0,2)"><m>b</m></label>
    <label anchor="(2.25,1.55)" alignment="ne" offset="(2,2)"><m>y= f(x)</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(-0.5,-0.5,3.5,4.5)">
    <grid spacings="((-0.5,4,3.5),(-0.5,5,4.5))" stroke="lightgray"/>
    <axes decorations="no"/>
    <definition>f2(x) = sin(2*x) + 2.5</definition>
    <area-under-curve function="f2" domain="(0.2,2.8)" fill="lightred"/>
    <riemann-sum function="f2" N="1" domain="(1,1.6)" rule="left" fill="lightgreen"/>
    <graph function="f2" stroke="blue"/>
    <label anchor="(0.2,-0.45)" alignment="n" offset="(0,2)"><m>a</m></label>
    <label anchor="(1,-0.5)" alignment="n" offset="(0,2)"><m>x_i</m></label>
    <label anchor="(1.3,1.7)" alignment="c"><m>B</m></label>
    <label anchor="(1.3,3.85)" alignment="c"><m>B = 2f(x_i) \triangle x</m></label>
    <label anchor="(1.6,-0.4)" alignment="n" offset="(2,-2)"><m>x_{i+1}</m></label>
    <label anchor="(2.8,-0.45)" alignment="n" offset="(0,2)"><m>b</m></label>
    <label anchor="(2.1,3)" alignment="ne" offset="(2,2)"><m>y= 2f(x)</m></label>
  </coordinates>
</diagram>
