<diagram xmlns="https://prefigure.org"
         dimensions="(300,150)">
  <coordinates destination="(10,10,140,140)"
               bbox="(-0.5,-6,3.5,6)">
    <grid spacings="((-0.5,0.5,3.5),(-6,1.5,6))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(1,2,3)" vlabels="(-4.5,1.5,4.5)"/>
    <definition>f1(x) = 3</definition>
    <riemann-sum function="f1" N="1" domain="(0,1.5)" rule="left" fill="lightgreen"/>
    <graph function="f1" stroke="blue" domain="(0,1.5)"/>
    <definition>f2(x) = -4</definition>
    <riemann-sum function="f2" N="1" domain="(1.5,2)" rule="left" fill="lightgreen"/>
    <graph function="f2" stroke="blue" domain="(1.5,2)"/>
    <definition>f3(x) = 3</definition>
    <riemann-sum function="f3" N="1" domain="(2,3)" rule="left" fill="lightgreen"/>
    <graph function="f3" stroke="blue" domain="(2,3)"/>
    <label anchor="(0.1,5)" alignment="ne" offset="(2,0)">mph</label>
    <label anchor="(3,0.5)" alignment="ne" offset="(2,2)">hrs</label>
    <label anchor="(0.75,1.5)" alignment="c" scale="0.75"><m>A_1 = 4.5</m></label>
    <label anchor="(1.75,-2)" alignment="c" offset="(5,0)" scale="0.75"><m>A_2 = 2</m></label>
    <label anchor="(2.5,1.5)" alignment="c" scale="0.75"><m>A_3 = 3</m></label>
    <label anchor="(1.5,3)" alignment="nw" offset="(-2,2)" scale="0.75"><m>y=v(t)</m></label>
  </coordinates>

  <coordinates destination="(160,10,290,140)"
               bbox="(-0.5,-6,3.5,6)">
    <grid spacings="((-0.5,0.5,3.5),(-6,1.5,6))" stroke="lightgray"/>
    <axes decorations="no" hlabels="(1,2,3)" vlabels="(-4.5,1.5,4.5)"/>
    <label anchor="(0.1,5)" alignment="ne" offset="(2,0)">miles</label>
    <label anchor="(3,0.5)" alignment="ne" offset="(2,2)">hrs</label>
    <definition>f1(x) = 3*x</definition>
    <graph function="f1" stroke="blue" domain="(0,1.5)"/>
    <definition>f2(x) = 4.5 - 4*(x-1.5)</definition>
    <graph function="f2" stroke="blue" domain="(1.5,2)"/>
    <definition>f3(x) = 2.5 + 3*(x-2)</definition>
    <graph function="f3" stroke="blue" domain="(2,3)"/>
    <point p="(1.5,4.5)" size="1.5" fill="red"/>
    <label anchor="(1.5,4.5)" alignment="ne" offset="(2,2)" scale="0.75"><m>(1.5,4.5)</m></label>
    <point p="(2,2.5)" size="1.5" fill="red"/>
    <label anchor="(2,2.5)" alignment="se" offset="(2,-2)" scale="0.75"><m>(2,2.5)</m></label>
    <point p="(3,5.5)" size="1.5" fill="red"/>
    <label anchor="(3,5.5)" alignment="ne" offset="(2,2)" scale="0.75"><m>(3,5.5)</m></label>
    <label anchor="(1,3)" alignment="nw" offset="(-2,2)" scale="0.75"><m>y=s(t)</m></label>
  </coordinates>
</diagram>
